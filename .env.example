# ============================================
# 收银系统环境配置模板
# ============================================
# 复制此文件为 .env 并根据需要修改配置
# 命令: cp .env.example .env

# ============================================
# 应用配置
# ============================================
APP_VERSION=2.5.4
APP_NAME="Cashier System"

# ============================================
# 数据库配置
# ============================================
# 数据库类型: docker, local, none
DB_TYPE=docker

# Docker 配置
MYSQL_CONTAINER_NAME=cashier-mysql
MYSQL_IMAGE=mysql:8.4
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=cashier_system
MYSQL_USER=cashier
MYSQL_PASSWORD=CHANGE_ME_APP_PASSWORD

# 连接配置
DB_HOST=localhost
DB_PORT=3306

# 时区
TZ=Asia/Shanghai

# ============================================
# JVM 配置
# ============================================
JVM_OPTS=-Xms512m -Xmx1024m -Dfile.encoding=UTF-8

# ============================================
# 安全提示
# ============================================
# ⚠️ 生产环境请务必修改以下密码：
#   - MYSQL_ROOT_PASSWORD
#   - MYSQL_PASSWORD
