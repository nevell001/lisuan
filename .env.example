# ============================================
# 收银系统环境配置模板
# ============================================
# 复制此文件为 .env 并根据需要修改配置
# 命令: cp .env.example .env

# ============================================
# 应用配置
# ============================================
APP_VERSION=2.5.7
APP_NAME="LiSuan System"

# 环境类型: development 或 production
# development - 开发环境（使用 root 用户连接数据库）
# production - 生产环境（使用专用用户 lisuan 连接数据库）
ENVIRONMENT=development

# ============================================
# 数据库配置
# ============================================
# 数据库类型: docker, local, none
DB_TYPE=docker

# Docker 配置
MYSQL_CONTAINER_NAME=lisuan-mysql
MYSQL_IMAGE=mysql:8.4
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=lisuan_system
MYSQL_USER=lisuan
MYSQL_PASSWORD=CHANGE_ME_APP_PASSWORD

# 连接配置
DB_HOST=localhost
DB_PORT=3306

# 时区
TZ=Asia/Shanghai

# ============================================
# JVM 配置
# ============================================
JVM_OPTS=-Xms512m -Xmx1024m -Dfile.encoding=UTF-8

# ============================================
# API 安全配置（生产环境必需）
# ============================================
# Token 密钥 - 用于生成和验证 API Token
# ⚠️ 生产环境必须设置为一个强随机字符串（至少32位）
TOKEN_SECRET=CHANGE_ME_TOKEN_SECRET_PLEASE_USE_RANDOM_32CHARS

# CORS 允许的来源 - 指定哪些域名可以访问 API
# ⚠️ 生产环境必须设置，多个域名用逗号分隔
# 示例: CORS_ALLOWED_ORIGINS=https://pos.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ============================================
# 安全提示
# ============================================
# ⚠️ 生产环境请务必修改以下配置：
#   - MYSQL_ROOT_PASSWORD
#   - MYSQL_PASSWORD
#   - TOKEN_SECRET（必须使用强随机字符串）
#   - CORS_ALLOWED_ORIGINS（必须限制允许的域名）
#   - 建议启用数据库 SSL（设置 DB_USE_SSL=true）
