# API 服务器配置
# ============================================
# ⚠️ 安全警告：生产环境请使用环境变量！
# ============================================
# 推荐方式（更安全）：
#   export TOKEN_SECRET="your_random_64_char_secret"
#   export CORS_ALLOWED_ORIGINS="https://your-domain.com"
# ============================================

# API 服务器开关
api.enabled=true

# API 端口
api.port=8080

# API 主机绑定（生产环境建议改为具体IP）
api.host=0.0.0.0

# ============================================
# CORS 配置（重要！）
# ============================================
# 开发环境: * (允许所有来源)
# 生产环境: 必须限制为具体域名，多个域名用逗号分隔
# 示例: https://pos.example.com,https://admin.example.com
cors.allowed.origins=*

# Token 过期时间（小时）
token.expire.hours=24

# ============================================
# TOKEN 密钥（重要！）
# ============================================
# ⚠️ 生产环境必须使用强随机密钥（至少64字符）
# ⚠️ 建议使用环境变量 TOKEN_SECRET 设置
# 生成方式: openssl rand -base64 48
token.secret=your_secret_key_change_this_in_production