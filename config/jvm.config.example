# JVM 配置文件 (Windows)
# 用于收银系统的 JVM 参数配置
# 根据系统资源调整以下参数

# ============================================
# 内存设置
# ============================================
# 初始堆内存大小
-Xms512m

# 最大堆内存大小 (建议根据实际需求调整)
# 小型系统: 512m - 1024m
# 中型系统: 1024m - 2048m
# 大型系统: 2048m - 4096m
-Xmx1024m

# 年轻代内存大小
-Xmn256m

# ============================================
# 性能优化
# ============================================
# 启用并行垃圾回收器
-XX:+UseParallelGC

# GC 线程数 (建议设置为 CPU 核心数)
-XX:ParallelGCThreads=4

# 启用编译优化
-XX:+AggressiveOpts

# JIT 编译阈值
-XX:CompileThreshold=1000

# ============================================
# Windows 特定优化
# ============================================
# 启用 DPI 感知 (高分辨率屏幕支持)
-Dsun.java2d.dpiaware=true

# 启用 OpenGL 加速 (如果显卡支持)
-Dsun.java2d.opengl=true

# 禁用 DirectDraw (解决某些显卡兼容性问题)
-Dsun.java2d.d3d=false

# ============================================
# 系统属性
# ============================================
# 文件编码
-Dfile.encoding=UTF-8

# 默认时区
-Duser.timezone=Asia/Shanghai

# 启用断言
-ea

# ============================================
# 日志和调试
# ============================================
# 日志文件路径
-Djava.util.logging.config.file=config/logging.properties

# 启用详细 GC 日志 (需要调试时取消注释)
# -XX:+PrintGCDetails
# -XX:+PrintGCTimeStamps
# -Xlog:gc*:logs\gc.log:time

# ============================================
# JavaFX 特定设置
# ============================================
# 启用硬件加速
-Dprism.order=d3d,sw

# 最大纹理大小
-Dprism.maxTextureSize=4096

# 启用多线程渲染
-Dprism.threadCount=4

# ============================================
# 其他
# ============================================
# 临时文件目录
-Djava.io.tmpdir=temp

# 启用类数据共享 (可选)
-Xshare:auto