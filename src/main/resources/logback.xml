<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 开发环境配置 -->
    <springProperty scope="context" name="APP_ENV" source="spring.profiles.active" defaultValue="dev"/>
    
    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 文件输出 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/cashier-system.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/cashier-system.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 错误日志单独输出 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>90</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- 异步输出，提高性能 -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="FILE" />
    </appender>

    <!-- 异步输出错误日志 -->
    <appender name="ASYNC_ERROR_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="ERROR_FILE" />
    </appender>

    <!-- 开发环境配置 -->
    <springProfile name="dev">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="ASYNC_FILE" />
            <appender-ref ref="ASYNC_ERROR_FILE" />
        </root>
        
        <!-- 开发环境详细日志 -->
        <logger name="com.cashier.dao" level="DEBUG" />
        <logger name="com.cashier.util.DatabaseManager" level="DEBUG" />
        <logger name="com.cashier.service" level="DEBUG" />
        <logger name="com.cashier.controller" level="DEBUG" />
        <logger name="com.cashier.util.CacheManager" level="DEBUG" />
    </springProfile>

    <!-- 生产环境配置 -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="ASYNC_FILE" />
            <appender-ref ref="ASYNC_ERROR_FILE" />
        </root>
        
        <!-- 生产环境简化日志 -->
        <logger name="com.cashier.dao" level="WARN" />
        <logger name="com.cashier.util.DatabaseManager" level="WARN" />
        <logger name="com.cashier.service" level="INFO" />
        <logger name="com.cashier.controller" level="INFO" />
        <logger name="com.cashier.util.CacheManager" level="INFO" />
        
        <!-- 性能相关日志 -->
        <logger name="com.cashier" level="INFO" />
    </springProfile>

    <!-- 默认配置（等同于开发环境） -->
    <if condition='!isDefined("APP_ENV") || !("prod".equals("${APP_ENV}"))'>
        <root level="DEBUG">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="ASYNC_FILE" />
            <appender-ref ref="ASYNC_ERROR_FILE" />
        </root>
        
        <!-- 默认环境详细日志 -->
        <logger name="com.cashier.dao" level="DEBUG" />
        <logger name="com.cashier.util.DatabaseManager" level="DEBUG" />
        <logger name="com.cashier.service" level="DEBUG" />
        <logger name="com.cashier.controller" level="DEBUG" />
        <logger name="com.cashier.util.CacheManager" level="DEBUG" />
    </if>

</configuration>