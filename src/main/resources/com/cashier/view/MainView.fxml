<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cashier.controller.MainController"
            styleClass="scene">

    <!-- 顶部标题栏 -->
    <top>
        <VBox>
            <!-- 菜单栏 -->
            <MenuBar>
                <Menu text="%menu.system">
                    <MenuItem text="%menu.system.logout" onAction="#handleLogout"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="%menu.system.exit" onAction="#handleExit"/>
                </Menu>
                <Menu text="%menu.data">
                    <MenuItem text="%menu.data.backup" onAction="#handleDataBackup"/>
                    <MenuItem text="%menu.data.restore" onAction="#handleDataRestore"/>
                </Menu>
                <Menu text="%menu.theme">
                    <MenuItem text="%menu.theme.light" onAction="#handleLightTheme"/>
                    <MenuItem text="%menu.theme.dark" onAction="#handleDarkTheme"/>
                    <MenuItem text="%menu.theme.intellij" onAction="#handleIntelliJTheme"/>
                </Menu>
                <Menu text="%menu.help">
                    <MenuItem text="%menu.help.about" onAction="#handleAbout"/>
                </Menu>
            </MenuBar>

            <!-- 工具栏 -->
            <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="8" right="10" bottom="8" left="10"/>
                </padding>

                <Label text="%app.name" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="currentUserLabel" style="-fx-font-size: 14px; -fx-text-fill: #616161;"/>
                <Label fx:id="currentTimeLabel" style="-fx-font-size: 14px; -fx-text-fill: #616161;"/>
            </HBox>
        </VBox>
    </top>

    <!-- 左侧导航栏 -->
    <left>
        <VBox spacing="0" styleClass="sidebar" prefWidth="260">
            <!-- 用户信息卡片 -->
            <VBox spacing="8" styleClass="user-card">
                <padding>
                    <Insets top="20" right="15" bottom="20" left="15"/>
                </padding>

                <!-- 头像 -->
                <HBox alignment="CENTER" style="-fx-padding-bottom: 10;">
                    <StackPane styleClass="avatar-circle">
                        <Label fx:id="avatarLabel"
                               text="A"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
                    </StackPane>
                </HBox>

                <Label fx:id="userNameLabel"
                       text="%login.username"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #212121;"/>
                <Label fx:id="userRoleLabel"
                       text="%user.role_label"
                       style="-fx-font-size: 13px; -fx-text-fill: #616161;"/>
            </VBox>

            <!-- 导航按钮 -->
            <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER">
                <VBox spacing="2" styleClass="nav-buttons">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>

                    <Button fx:id="cartBtn"
                            text="%nav.cart"
                            onAction="#handleCart"
                            styleClass="nav-button, nav-button-active">
                        <graphic>
                            <Label text="🛒" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="inventoryBtn"
                            text="%nav.inventory"
                            onAction="#handleInventory"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="📦" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="membersBtn"
                            text="%nav.members"
                            onAction="#handleMembers"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="👥" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Separator/>

                    <Button fx:id="supplierBtn"
                            text="%nav.supplier"
                            onAction="#handleSupplier"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="🏭" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="purchaseOrderBtn"
                            text="%nav.purchase_order"
                            onAction="#handlePurchaseOrder"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="📝" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="purchaseApprovalBtn"
                            text="%nav.purchase_approval"
                            onAction="#handlePurchaseApproval"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="✅" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="purchaseInboundBtn"
                            text="%nav.purchase_inbound"
                            onAction="#handlePurchaseInbound"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="📥" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="inventoryCheckBtn"
                            text="%nav.inventory_check"
                            onAction="#handleInventoryCheck"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="🔍" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Separator/>

                    <Button fx:id="promotionsBtn"
                            text="%nav.promotions"
                            onAction="#handlePromotions"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="🎉" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="transactionsBtn"
                            text="%nav.transactions"
                            onAction="#handleTransactions"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="📊" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="statisticsBtn"
                            text="%nav.statistics"
                            onAction="#handleStatistics"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="📈" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Separator/>

                    <Button fx:id="purchaseReportBtn"
                            text="%nav.purchase_report"
                            onAction="#handlePurchaseReport"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="📊" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="inventoryReportBtn"
                            text="%nav.inventory_report"
                            onAction="#handleInventoryReport"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="📉" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="profitReportBtn"
                            text="%nav.profit_report"
                            onAction="#handleProfitReport"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="💰" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="returnReportBtn"
                            text="%nav.return_report"
                            onAction="#handleReturnReport"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="📈" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Separator/>

                    <Button fx:id="shiftBtn"
                            text="%nav.shift"
                            onAction="#handleShift"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="🔄" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="userManagementBtn"
                            text="%nav.user_management"
                            onAction="#handleUserManagement"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="👤" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="returnOrderBtn"
                            text="%nav.return_order"
                            onAction="#handleReturnOrder"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="↩" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="returnApprovalBtn"
                            text="%nav.return_approval"
                            onAction="#handleReturnApproval"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="✓" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>

                    <Button fx:id="settingsBtn"
                            text="%nav.settings"
                            onAction="#handleSettings"
                            styleClass="nav-button">
                        <graphic>
                            <Label text="⚙" style="-fx-font-size: 16px; -fx-font-family: 'Segoe UI Symbol', 'Microsoft YaHei', sans-serif;"/>
                        </graphic>
                    </Button>
                </VBox>
            </ScrollPane>
        </VBox>
    </left>

    <!-- 主内容区域 -->
    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="ALL_TABS" styleClass="main-tab-pane">
            <!-- 默认欢迎标签页 -->
            <Tab text="%main.welcome" closable="false">
                <VBox alignment="CENTER" spacing="20" styleClass="welcome-panel">
                    <padding>
                        <Insets top="40" right="40" bottom="40" left="40"/>
                    </padding>

                    <Label text="%main.welcome.title"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
                    <Label text="%main.welcome.subtitle"
                           style="-fx-font-size: 16px; -fx-text-fill: #9E9E9E;"/>

                    <HBox spacing="20" alignment="CENTER" style="-fx-padding-top: 30;">
                        <Button text="%main.get_started"
                                onAction="#handleCart"
                                prefWidth="120"
                                prefHeight="40"
                                styleClass="primary-button"/>
                        <Button text="%main.view_help"
                                onAction="#handleAbout"
                                prefWidth="120"
                                prefHeight="40"
                                styleClass="secondary-button"/>
                    </HBox>
                </VBox>
            </Tab>
        </TabPane>
    </center>

    <!-- 底部状态栏 -->
    <bottom>
        <HBox spacing="10" styleClass="status-bar" alignment="CENTER_LEFT">
            <padding>
                <Insets top="5" right="10" bottom="5" left="10"/>
            </padding>

            <Label fx:id="statusLabel" text="%status.ready" style="-fx-text-fill: #616161;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="currentShiftLabel" text="%status.shift_not_started" style="-fx-text-fill: #616161;"/>
            <Separator orientation="VERTICAL"/>
            <Label fx:id="dateLabel" style="-fx-text-fill: #616161;"/>
        </HBox>
    </bottom>

</BorderPane>
