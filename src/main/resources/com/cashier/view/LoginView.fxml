<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.LoginController"
      alignment="CENTER"
      spacing="20"
      styleClass="login-scene">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <!-- 标题区域 -->
    <VBox alignment="CENTER" spacing="10">
        <Label text="%app.name"
               styleClass="login-title"/>
        <Label text="%app.subtitle"
               styleClass="login-subtitle"/>
    </VBox>

    <!-- 登录表单 -->
    <VBox fx:id="loginCard" spacing="20" styleClass="login-card">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- 用户名 -->
        <VBox spacing="8">
            <Label text="%login.username" styleClass="form-label"/>
            <TextField fx:id="usernameField"
                       promptText="%login.username"
                       prefWidth="300"
                       styleClass="login-input"/>
        </VBox>

        <!-- 密码 -->
        <VBox spacing="8">
            <Label text="%login.password" styleClass="form-label"/>
            <PasswordField fx:id="passwordField"
                          promptText="%login.password"
                          prefWidth="300"
                          styleClass="login-input"
                          onAction="#handleLogin"/>
        </VBox>

        <!-- 记住密码 -->
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding-top: 5;">
            <CheckBox fx:id="rememberMeCheckBox" text="%login.remember" styleClass="remember-checkbox"/>
            <HBox HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- 错误提示 -->
        <Label fx:id="errorLabel"
               styleClass="error-label"
               visible="false"/>

        <!-- 加载指示器 -->
        <ProgressIndicator fx:id="loadingIndicator"
                          styleClass="loading-indicator"
                          visible="false"
                          managed="false"/>

        <!-- 按钮 -->
        <VBox spacing="12" style="-fx-padding-top: 10;">
            <Button text="%login.button"
                    onAction="#handleLogin"
                    prefWidth="300"
                    prefHeight="45"
                    styleClass="login-button"/>
            <HBox spacing="10" alignment="CENTER">
                <Button text="%login.exit"
                        onAction="#handleExit"
                        prefWidth="145"
                        prefHeight="38"
                        styleClass="secondary-button"/>
                <Button text="%menu.help.about"
                        onAction="#handleAbout"
                        prefWidth="145"
                        prefHeight="38"
                        styleClass="secondary-button"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- 提示信息 -->
    <VBox spacing="8" alignment="CENTER">
        <Label text="%login.default_account"
               styleClass="hint-label"/>
        <Label fx:id="versionLabel"
               styleClass="version-label"/>
    </VBox>

</VBox>
