<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.LoginController"
      alignment="CENTER"
      spacing="20"
      styleClass="scene">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <!-- 标题 -->
    <VBox alignment="CENTER" spacing="10">
        <Label text="收银系统"
               style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
        <Label text="Cashier System"
               style="-fx-font-size: 14px; -fx-text-fill: #9E9E9E;"/>
    </VBox>

    <!-- 登录表单 -->
    <VBox fx:id="loginCard" spacing="20" styleClass="card">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>

        <!-- 用户名 -->
        <VBox spacing="8">
            <Label text="用户名" style="-fx-font-weight: bold;"/>
            <TextField fx:id="usernameField"
                       promptText="请输入用户名"
                       prefWidth="280"
                       styleClass="text-field"/>
        </VBox>

        <!-- 密码 -->
        <VBox spacing="8">
            <Label text="密码" style="-fx-font-weight: bold;"/>
            <PasswordField fx:id="passwordField"
                          promptText="请输入密码"
                          prefWidth="280"
                          styleClass="text-field"
                          onAction="#handleLogin"/>
        </VBox>

        <!-- 记住密码 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <CheckBox fx:id="rememberMeCheckBox" text="记住密码"/>
        </HBox>

        <!-- 错误提示 -->
        <Label fx:id="errorLabel"
               style="-fx-text-fill: #D32F2F; -fx-font-size: 12px; -fx-wrap-text: true;"
               visible="false"/>

        <!-- 按钮 -->
        <HBox spacing="10" alignment="CENTER" style="-fx-padding-top: 10;">
            <Button text="登录"
                    onAction="#handleLogin"
                    prefWidth="120"
                    prefHeight="35"
                    styleClass="primary-button"/>
            <Button text="退出"
                    onAction="#handleExit"
                    prefWidth="120"
                    prefHeight="35"
                    styleClass="secondary-button"/>
        </HBox>
    </VBox>

    <!-- 提示信息 -->
    <VBox spacing="5" alignment="CENTER">
        <Label text="默认账户: admin / admin123"
               style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;"/>
        <Label fx:id="versionLabel"
               style="-fx-font-size: 11px; -fx-text-fill: #BDBDBD;"/>
    </VBox>

</VBox>
