<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.RechargeController"
      spacing="15"
      styleClass="recharge-view"
      prefWidth="500"
      prefHeight="550">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- 标题 -->
    <Label text="%recharge.title"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>

    <!-- 会员信息 -->
    <VBox spacing="5" styleClass="member-info-box">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>
        <HBox spacing="10">
            <Label text="%recharge.member_name" style="-fx-font-weight: bold;"/>
            <Label fx:id="memberNameLabel" text=""/>
        </HBox>
        <HBox spacing="10">
            <Label text="%recharge.phone" style="-fx-font-weight: bold;"/>
            <Label fx:id="memberPhoneLabel" text=""/>
        </HBox>
        <HBox spacing="10">
            <Label text="%recharge.current_balance" style="-fx-font-weight: bold;"/>
            <Label fx:id="currentBalanceLabel" text="" style="-fx-text-fill: #4CAF50; -fx-font-weight: bold;"/>
        </HBox>
        <HBox spacing="10">
            <Label text="%recharge.current_points" style="-fx-font-weight: bold;"/>
            <Label fx:id="currentPointsLabel" text="" style="-fx-text-fill: #FF9800; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>

    <!-- 充值表单 -->
    <GridPane hgap="10" vgap="10">
        <padding>
            <Insets top="10" right="0" bottom="10" left="0"/>
        </padding>

        <!-- 充值金额 -->
        <Label text="%recharge.amount" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="amountField"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"
                   prefWidth="200" promptText="%recharge.amount_hint"/>

        <!-- 支付方式 -->
        <Label text="%recharge.payment_method" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="paymentMethodComboBox"
                  GridPane.columnIndex="1" GridPane.rowIndex="1"
                  prefWidth="200"/>
    </GridPane>

    <!-- 预览信息 -->
    <VBox spacing="5" styleClass="preview-box">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>
        <HBox spacing="10">
            <Label text="%recharge.new_balance" style="-fx-font-weight: bold;"/>
            <Label fx:id="newBalanceLabel" text="" style="-fx-text-fill: #4CAF50; -fx-font-weight: bold; -fx-font-size: 14px;"/>
        </HBox>
        <HBox spacing="10">
            <Label text="%recharge.bonus_points" style="-fx-font-weight: bold;"/>
            <Label fx:id="bonusPointsLabel" text="" style="-fx-text-fill: #FF9800; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Label text="%recharge.points_hint" style="-fx-text-fill: #757575; -fx-font-size: 12px;"/>
        </HBox>
    </VBox>

    <!-- 充值历史记录 -->
    <VBox spacing="5">
        <Label text="%recharge.history" style="-fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
        <TableView fx:id="historyTable" prefHeight="150">
            <columns>
                <TableColumn fx:id="dateColumn" text="%recharge.date" prefWidth="140"/>
                <TableColumn fx:id="amountColumn" text="%recharge.amount_column" prefWidth="80"/>
                <TableColumn fx:id="paymentColumn" text="%recharge.payment_column" prefWidth="80"/>
                <TableColumn fx:id="operatorColumn" text="%recharge.operator" prefWidth="80"/>
            </columns>
        </TableView>
    </VBox>

    <!-- 按钮区域 -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="cancelButton"
                text="%recharge.cancel"
                onAction="#handleCancel"
                prefWidth="80"
                styleClass="secondary-button"/>
        <Button fx:id="okButton"
                text="%recharge.confirm"
                onAction="#handleOk"
                prefWidth="100"
                styleClass="primary-button"/>
    </HBox>

</VBox>
