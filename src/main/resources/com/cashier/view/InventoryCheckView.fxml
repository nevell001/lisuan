<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.InventoryCheckController"
      spacing="0"
      styleClass="inventory-check-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 操作按钮 -->
        <Button fx:id="addButton"
                text="%inventory_check.add"
                onAction="#handleAddCheck"
                prefWidth="100"
                styleClass="primary-button"/>

        <Button fx:id="editButton"
                text="%inventory_check.edit"
                onAction="#handleEditCheck"
                prefWidth="80"
                disable="true"
                styleClass="secondary-button"/>

        <Button fx:id="deleteButton"
                text="%inventory_check.delete"
                onAction="#handleDeleteCheck"
                prefWidth="80"
                disable="true"
                styleClass="danger-button"/>

        <Button fx:id="viewDetailButton"
                text="%inventory_check.view_detail"
                onAction="#handleViewDetail"
                prefWidth="100"
                disable="true"
                styleClass="info-button"/>

        <Button fx:id="completeButton"
                text="%inventory_check.complete"
                onAction="#handleComplete"
                prefWidth="100"
                disable="true"
                styleClass="success-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 筛选 -->
        <Label text="%inventory_check.status_label"/>
        <ComboBox fx:id="statusFilterCombo"
                  prefWidth="100"
                  onAction="#handleStatusFilter"/>

        <Separator orientation="VERTICAL"/>

        <!-- 搜索 -->
        <Label text="%inventory_check.search_label"/>
        <TextField fx:id="searchField"
                  promptText="%inventory_check.search_hint"
                  prefWidth="200"
                  onAction="#handleSearch"/>

        <Button text="%common.search"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 统计信息 -->
        <Label fx:id="countLabel" text="%inventory_check.count" style="-fx-text-fill: #757575;"/>
    </HBox>

    <!-- 库存盘点表格 -->
    <TableView fx:id="checkTable"
              VBox.vgrow="ALWAYS"
              styleClass="inventory-check-table">
        <columns>
            <TableColumn fx:id="checkNoColumn" text="%inventory_check.check_no" prefWidth="150"/>
            <TableColumn fx:id="checkDateColumn" text="%inventory_check.check_date" prefWidth="100"/>
            <TableColumn fx:id="checkTypeColumn" text="%inventory_check.check_type" prefWidth="100"/>
            <TableColumn fx:id="totalItemsColumn" text="%inventory_check.total_items" prefWidth="80"/>
            <TableColumn fx:id="diffItemsColumn" text="%inventory_check.diff_items" prefWidth="80"/>
            <TableColumn fx:id="statusColumn" text="%inventory_check.status" prefWidth="80"/>
            <TableColumn fx:id="operatorColumn" text="%inventory_check.operator" prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="%inventory_check.no_data" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>
