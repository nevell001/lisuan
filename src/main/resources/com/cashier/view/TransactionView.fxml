<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.TransactionController"
      spacing="0"
      styleClass="transaction-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 筛选条件 -->
        <Label text="开始日期:"/>
        <DatePicker fx:id="startDatePicker" prefWidth="150"/>

        <Label text="结束日期:"/>
        <DatePicker fx:id="endDatePicker" prefWidth="150"/>

        <Label text="支付方式:"/>
        <ComboBox fx:id="paymentMethodComboBox" prefWidth="100"/>

        <Separator orientation="VERTICAL"/>

        <!-- 搜索 -->
        <Label text="搜索:"/>
        <TextField fx:id="searchField"
                  promptText="订单号或会员手机号"
                  prefWidth="200"
                  onAction="#handleSearch"/>

        <Button text="搜索"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button text="清除"
                onAction="#handleClearSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 操作按钮 -->
        <Button fx:id="viewDetailButton"
                text="查看详情"
                onAction="#handleViewDetail"
                prefWidth="80"
                styleClass="primary-button"/>

        <Button fx:id="createReturnButton"
                text="创建退货"
                onAction="#handleCreateReturn"
                prefWidth="80"
                styleClass="warning-button"/>

        <Button fx:id="exportButton"
                text="导出"
                onAction="#handleExport"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button fx:id="refreshButton"
                text="刷新"
                onAction="#handleRefresh"
                prefWidth="60"
                styleClass="secondary-button"/>
    </HBox>

    <!-- 统计信息栏 -->
    <HBox spacing="20" styleClass="status-bar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="5" right="10" bottom="5" left="10"/>
        </padding>
        <Label fx:id="countLabel" text="交易数量: 0" style="-fx-font-size: 13px; -fx-text-fill: #757575;"/>
        <Label fx:id="totalAmountLabel" text="总金额: ¥0.00" style="-fx-font-size: 13px; -fx-text-fill: #4CAF50; -fx-font-weight: bold;"/>
    </HBox>

    <!-- 交易记录表格 -->
    <TableView fx:id="transactionTable"
              VBox.vgrow="ALWAYS"
              styleClass="transaction-table">
        <columns>
            <TableColumn fx:id="transactionIdColumn" text="订单号" prefWidth="150"/>
            <TableColumn fx:id="timestampColumn" text="交易时间" prefWidth="160"/>
            <TableColumn fx:id="itemsColumn" text="商品" prefWidth="250"/>
            <TableColumn fx:id="amountColumn" text="金额(元)" prefWidth="100"/>
            <TableColumn fx:id="paymentColumn" text="支付方式" prefWidth="80"/>
            <TableColumn fx:id="memberColumn" text="会员" prefWidth="120"/>
        </columns>
        <placeholder>
            <Label text="暂无交易记录" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>