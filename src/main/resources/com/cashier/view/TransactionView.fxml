<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.TransactionController"
      spacing="0"
      styleClass="transaction-view">

    <!-- 顶部工具栏 -->
    <VBox spacing="5" styleClass="toolbar">
        <!-- 第一行：筛选条件 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="5" left="10"/>
            </padding>

            <Label text="%transaction.date_from"/>
            <DatePicker fx:id="startDatePicker" prefWidth="150"/>

            <Label text="%transaction.date_to"/>
            <DatePicker fx:id="endDatePicker" prefWidth="150"/>

            <Label text="%transaction.payment_method"/>
            <ComboBox fx:id="paymentMethodComboBox" prefWidth="100"/>
        </HBox>

        <!-- 第二行：搜索和操作按钮 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="5" right="10" bottom="10" left="10"/>
            </padding>

            <Label text="%transaction.search_label"/>
            <TextField fx:id="searchField"
                      promptText="%transaction.search_hint"
                      prefWidth="200"
                      onAction="#handleSearch"/>

            <Button text="%transaction.search_button"
                    onAction="#handleSearch"
                    prefWidth="60"
                    styleClass="secondary-button"/>

            <Button text="%common.clear"
                    onAction="#handleClearSearch"
                    prefWidth="60"
                    styleClass="secondary-button"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="viewDetailButton"
                    text="%transaction.view_detail"
                    onAction="#handleViewDetail"
                    prefWidth="100"
                    styleClass="primary-button"/>

            <Button fx:id="createReturnButton"
                    text="%transaction.create_return"
                    onAction="#handleCreateReturn"
                    prefWidth="100"
                    styleClass="warning-button"/>

            <Button fx:id="exportButton"
                    text="%transaction.export"
                    onAction="#handleExport"
                    prefWidth="60"
                    styleClass="secondary-button"/>

            <Button fx:id="refreshButton"
                    text="%transaction.refresh_button"
                    onAction="#handleRefresh"
                    prefWidth="60"
                    styleClass="secondary-button"/>
        </HBox>
    </VBox>

    <!-- 统计信息栏 -->
    <HBox spacing="20" styleClass="status-bar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="5" right="10" bottom="5" left="10"/>
        </padding>
        <Label fx:id="countLabel" text="%transaction.count" style="-fx-font-size: 13px; -fx-text-fill: #757575;"/>
        <Label fx:id="totalAmountLabel" text="%transaction.total_amount" style="-fx-font-size: 13px; -fx-text-fill: #4CAF50; -fx-font-weight: bold;"/>
    </HBox>

    <!-- 交易记录表格 -->
    <TableView fx:id="transactionTable"
              VBox.vgrow="ALWAYS"
              styleClass="transaction-table">
        <columns>
            <TableColumn fx:id="transactionIdColumn" text="%transaction.order_id" prefWidth="150"/>
            <TableColumn fx:id="timestampColumn" text="%transaction.time_column" prefWidth="160"/>
            <TableColumn fx:id="itemsColumn" text="%transaction.items_column" prefWidth="250"/>
            <TableColumn fx:id="amountColumn" text="%transaction.amount_column" prefWidth="100"/>
            <TableColumn fx:id="paymentColumn" text="%transaction.payment_column" prefWidth="80"/>
            <TableColumn fx:id="memberColumn" text="%transaction.member_column" prefWidth="120"/>
        </columns>
        <placeholder>
            <Label text="%transaction.no_data" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>