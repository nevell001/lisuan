<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.SupplierController"
      spacing="0"
      styleClass="supplier-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 操作按钮 -->
        <Button fx:id="addButton"
                text="%supplier.add"
                onAction="#handleAddSupplier"
                prefWidth="120"
                styleClass="primary-button"/>

        <Button fx:id="editButton"
                text="%supplier.edit_button"
                onAction="#handleEditSupplier"
                prefWidth="80"
                disable="true"
                styleClass="secondary-button"/>

        <Button fx:id="deleteButton"
                text="%supplier.delete_button"
                onAction="#handleDeleteSupplier"
                prefWidth="80"
                disable="true"
                styleClass="danger-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 搜索 -->
        <Label text="%supplier.search_label"/>
        <TextField fx:id="searchField"
                  promptText="%supplier.search_hint"
                  prefWidth="200"
                  onAction="#handleSearch"/>

        <Button text="%common.search"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button text="%common.clear"
                onAction="#handleClearSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 统计信息 -->
        <Label fx:id="countLabel" text="%supplier.count" style="-fx-text-fill: #757575;"/>
    </HBox>

    <!-- 供应商表格 -->
    <TableView fx:id="supplierTable"
              VBox.vgrow="ALWAYS"
              styleClass="supplier-table">
        <columns>
            <TableColumn fx:id="codeColumn" text="%supplier.code" prefWidth="120" minWidth="100"/>
            <TableColumn fx:id="nameColumn" text="%supplier.name" prefWidth="180" minWidth="150"/>
            <TableColumn fx:id="contactColumn" text="%supplier.contact" prefWidth="100" minWidth="80"/>
            <TableColumn fx:id="phoneColumn" text="%supplier.phone" prefWidth="120" minWidth="100"/>
            <TableColumn fx:id="rankColumn" text="%supplier.rank" prefWidth="60" minWidth="50"/>
            <TableColumn fx:id="statusColumn" text="%supplier.status" prefWidth="60" minWidth="50"/>
            <TableColumn fx:id="addressColumn" text="%supplier.address" prefWidth="350" minWidth="250"/>
        </columns>
        <placeholder>
            <Label text="%supplier.no_data" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>