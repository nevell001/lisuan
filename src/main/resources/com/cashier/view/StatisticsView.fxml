<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.StatisticsController"
      spacing="0"
      styleClass="statistics-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 时间范围选择 -->
        <Label text="时间范围:"/>
        <ComboBox fx:id="timeRangeComboBox" prefWidth="120"/>

        <Label text="开始日期:"/>
        <DatePicker fx:id="startDatePicker" prefWidth="150"/>

        <Label text="结束日期:"/>
        <DatePicker fx:id="endDatePicker" prefWidth="150"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 操作按钮 -->
        <Button fx:id="queryButton"
                text="查询"
                onAction="#handleQuery"
                prefWidth="100"
                prefHeight="35"
                styleClass="primary-button"/>

        <Button fx:id="exportButton"
                text="导出"
                onAction="#handleExport"
                prefWidth="100"
                prefHeight="35"
                styleClass="secondary-button"/>
    </HBox>

    <!-- 统计卡片区域 -->
    <ScrollPane fitToWidth="true" VBox.vgrow="NEVER">
        <VBox spacing="10" styleClass="cards-container">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <!-- 第一行：主要指标 -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <!-- 总销售额 -->
                <VBox spacing="5" styleClass="stat-card" prefWidth="220" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="总销售额" style="-fx-text-fill: #757575; -fx-font-size: 13px;"/>
                    <Label fx:id="totalSalesLabel" text="¥0.00" style="-fx-text-fill: #3F51B5; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- 交易笔数 -->
                <VBox spacing="5" styleClass="stat-card" prefWidth="180" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="交易笔数" style="-fx-text-fill: #757575; -fx-font-size: 13px;"/>
                    <Label fx:id="transactionCountLabel" text="0" style="-fx-text-fill: #4CAF50; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- 平均交易额 -->
                <VBox spacing="5" styleClass="stat-card" prefWidth="200" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="平均交易额" style="-fx-text-fill: #757575; -fx-font-size: 13px;"/>
                    <Label fx:id="avgTransactionLabel" text="¥0.00" style="-fx-text-fill: #FF9800; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- 会员消费 -->
                <VBox spacing="5" styleClass="stat-card" prefWidth="200" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="会员消费" style="-fx-text-fill: #757575; -fx-font-size: 13px;"/>
                    <Label fx:id="memberSalesLabel" text="¥0.00" style="-fx-text-fill: #9C27B0; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- 第二行：支付方式 -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <!-- 现金支付 -->
                <VBox spacing="5" styleClass="stat-card" prefWidth="180" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="现金支付" style="-fx-text-fill: #757575; -fx-font-size: 13px;"/>
                    <Label fx:id="cashSalesLabel" text="¥0.00" style="-fx-text-fill: #607D8B; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- 微信支付 -->
                <VBox spacing="5" styleClass="stat-card" prefWidth="180" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="微信支付" style="-fx-text-fill: #757575; -fx-font-size: 13px;"/>
                    <Label fx:id="wechatSalesLabel" text="¥0.00" style="-fx-text-fill: #2196F3; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- 支付宝支付 -->
                <VBox spacing="5" styleClass="stat-card" prefWidth="180" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="支付宝支付" style="-fx-text-fill: #757575; -fx-font-size: 13px;"/>
                    <Label fx:id="alipaySalesLabel" text="¥0.00" style="-fx-text-fill: #03A9F4; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- 银行卡支付 -->
                <VBox spacing="5" styleClass="stat-card" prefWidth="180" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="银行卡支付" style="-fx-text-fill: #757575; -fx-font-size: 13px;"/>
                    <Label fx:id="cardSalesLabel" text="¥0.00" style="-fx-text-fill: #00BCD4; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
        </VBox>
    </ScrollPane>

    <!-- 图表区域 -->
    <ScrollPane fitToWidth="true" VBox.vgrow="NEVER" prefHeight="350">
        <HBox spacing="15" styleClass="charts-container">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- 支付方式分布饼图 -->
            <VBox spacing="5" styleClass="chart-card" prefWidth="350">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <Label text="支付方式分布" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
                <PieChart fx:id="paymentMethodPieChart" prefWidth="330" prefHeight="280" legendSide="RIGHT"/>
            </VBox>

            <!-- 销售趋势折线图 -->
            <VBox spacing="5" styleClass="chart-card" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <Label text="销售趋势" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                <LineChart fx:id="salesTrendLineChart" prefHeight="280">
                    <xAxis>
                        <CategoryAxis label="日期"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="销售额（元）"/>
                    </yAxis>
                </LineChart>
            </VBox>

            <!-- 分类销售柱状图 -->
            <VBox spacing="5" styleClass="chart-card" prefWidth="350">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <Label text="分类销售对比" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                <BarChart fx:id="categorySalesBarChart" prefWidth="330" prefHeight="280">
                    <xAxis>
                        <CategoryAxis label="分类"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="销售额（元）"/>
                    </yAxis>
                </BarChart>
            </VBox>
        </HBox>
    </ScrollPane>

    <!-- 详细统计区域 -->
    <SplitPane VBox.vgrow="ALWAYS" styleClass="statistics-split-pane">
        <!-- 左侧：商品和分类统计 -->
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- 热销商品 -->
            <VBox spacing="5" styleClass="info-box">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <Label text="热销商品" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <VBox spacing="3">
                        <Label text="商品名称" style="-fx-text-fill: #757575; -fx-font-size: 12px;"/>
                        <Label fx:id="topProductLabel" text="无" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="销售数量" style="-fx-text-fill: #757575; -fx-font-size: 12px;"/>
                        <Label fx:id="topProductCountLabel" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="销售金额" style="-fx-text-fill: #757575; -fx-font-size: 12px;"/>
                        <Label fx:id="topProductAmountLabel" text="¥0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- 分类统计表格 -->
            <Label text="分类统计" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
            <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS" styleClass="category-table">
                <columns>
                    <TableColumn fx:id="categoryNameColumn" text="分类名称" prefWidth="200"/>
                    <TableColumn fx:id="categoryCountColumn" text="销售数量" prefWidth="100"/>
                    <TableColumn fx:id="categoryAmountColumn" text="销售金额" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>

        <!-- 右侧：时段统计 -->
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <Label text="时段统计" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
            <TableView fx:id="hourlyTable" VBox.vgrow="ALWAYS" styleClass="hourly-table">
                <columns>
                    <TableColumn fx:id="hourColumn" text="时间段" prefWidth="120"/>
                    <TableColumn fx:id="hourCountColumn" text="交易笔数" prefWidth="100"/>
                    <TableColumn fx:id="hourAmountColumn" text="交易金额" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </SplitPane>

</VBox>