<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.ShiftController"
      spacing="0"
      styleClass="shift-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 开班和交班按钮 -->
        <Button fx:id="startShiftButton"
                text="开班"
                onAction="#handleStartShift"
                prefWidth="80"
                styleClass="primary-button"/>

        <Button fx:id="endShiftButton"
                text="交班"
                onAction="#handleEndShift"
                prefWidth="80"
                styleClass="warning-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 筛选条件 -->
        <Label text="开始日期:"/>
        <DatePicker fx:id="startDatePicker" prefWidth="150"/>

        <Label text="结束日期:"/>
        <DatePicker fx:id="endDatePicker" prefWidth="150"/>

        <Separator orientation="VERTICAL"/>

        <!-- 搜索 -->
        <Label text="搜索:"/>
        <TextField fx:id="searchField"
                  promptText="操作员姓名或班次ID"
                  prefWidth="200"
                  onAction="#handleSearch"/>

        <Button text="搜索"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button text="清除"
                onAction="#handleClearSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 操作按钮 -->
        <Button fx:id="viewDetailButton"
                text="查看详情"
                onAction="#handleViewDetail"
                prefWidth="80"
                styleClass="primary-button"/>

        <Button fx:id="exportButton"
                text="导出"
                onAction="#handleExport"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button fx:id="refreshButton"
                text="刷新"
                onAction="#handleRefresh"
                prefWidth="60"
                styleClass="secondary-button"/>
    </HBox>

    <!-- 统计信息栏 -->
    <HBox spacing="20" styleClass="status-bar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="5" right="10" bottom="5" left="10"/>
        </padding>
        <Label fx:id="countLabel" text="班次数量: 0" style="-fx-font-size: 13px; -fx-text-fill: #757575;"/>
        <Label fx:id="totalRevenueLabel" text="总营业额: ¥0.00" style="-fx-font-size: 13px; -fx-text-fill: #4CAF50; -fx-font-weight: bold;"/>
        <Label fx:id="totalTransactionLabel" text="总交易数: 0" style="-fx-font-size: 13px; -fx-text-fill: #FF9800; -fx-font-weight: bold;"/>
    </HBox>

    <!-- 图表区域 -->
    <ScrollPane fitToWidth="true" VBox.vgrow="NEVER" prefHeight="300">
        <HBox spacing="15" styleClass="charts-container">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- 班次收入对比柱状图 -->
            <VBox spacing="5" styleClass="chart-card" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <Label text="班次收入对比" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
                <BarChart fx:id="shiftRevenueBarChart" prefHeight="250">
                    <xAxis>
                        <CategoryAxis label="班次"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="营业额（元）"/>
                    </yAxis>
                </BarChart>
            </VBox>

            <!-- 支付方式分布饼图 -->
            <VBox spacing="5" styleClass="chart-card" prefWidth="400">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <Label text="支付方式分布" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                <PieChart fx:id="paymentMethodPieChart" prefWidth="380" prefHeight="250" legendSide="RIGHT"/>
            </VBox>
        </HBox>
    </ScrollPane>

    <!-- 交接班记录表格 -->
    <TableView fx:id="shiftTable"
              VBox.vgrow="ALWAYS"
              styleClass="shift-table">
        <columns>
            <TableColumn fx:id="shiftIdColumn" text="班次ID" prefWidth="150"/>
            <TableColumn fx:id="operatorColumn" text="操作员" prefWidth="120"/>
            <TableColumn fx:id="timeColumn" text="时间" prefWidth="160"/>
            <TableColumn fx:id="durationColumn" text="时长" prefWidth="100"/>
            <TableColumn fx:id="transactionColumn" text="交易数" prefWidth="80"/>
            <TableColumn fx:id="revenueColumn" text="营业额(元)" prefWidth="100"/>
            <TableColumn fx:id="paymentColumn" text="支付方式" prefWidth="300"/>
        </columns>
        <placeholder>
            <Label text="暂无交接班记录" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>