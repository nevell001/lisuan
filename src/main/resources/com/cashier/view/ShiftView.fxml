<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.ShiftController"
      spacing="0"
      styleClass="shift-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 开班和交班按钮 -->
        <Button fx:id="startShiftButton"
                text="%shift.start"
                onAction="#handleStartShift"
                prefWidth="80"
                styleClass="primary-button"/>

        <Button fx:id="endShiftButton"
                text="%shift.end"
                onAction="#handleEndShift"
                prefWidth="80"
                styleClass="warning-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 筛选条件 -->
        <Label text="%shift.date_from"/>
        <DatePicker fx:id="startDatePicker" prefWidth="150"/>

        <Label text="%shift.date_to"/>
        <DatePicker fx:id="endDatePicker" prefWidth="150"/>

        <Separator orientation="VERTICAL"/>

        <!-- 搜索 -->
        <Label text="%shift.search_label"/>
        <TextField fx:id="searchField"
                  promptText="%shift.search_hint"
                  prefWidth="200"
                  onAction="#handleSearch"/>

        <Button text="%common.search"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button text="%common.clear"
                onAction="#handleClearSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 操作按钮 -->
        <Button fx:id="viewDetailButton"
                text="%shift.view_detail"
                onAction="#handleViewDetail"
                prefWidth="80"
                styleClass="primary-button"/>

        <Button fx:id="exportButton"
                text="%shift.export"
                onAction="#handleExport"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button fx:id="refreshButton"
                text="%shift.refresh"
                onAction="#handleRefresh"
                prefWidth="60"
                styleClass="secondary-button"/>
    </HBox>

    <!-- 统计信息栏 -->
    <HBox spacing="20" styleClass="status-bar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="5" right="10" bottom="5" left="10"/>
        </padding>
        <Label fx:id="countLabel" text="%shift.count" style="-fx-font-size: 13px; -fx-text-fill: #757575;"/>
        <Label fx:id="totalRevenueLabel" text="%shift.total_revenue" style="-fx-font-size: 13px; -fx-text-fill: #4CAF50; -fx-font-weight: bold;"/>
        <Label fx:id="totalTransactionLabel" text="%shift.total_transactions" style="-fx-font-size: 13px; -fx-text-fill: #FF9800; -fx-font-weight: bold;"/>
    </HBox>

    <!-- 图表区域 -->
    <ScrollPane fitToWidth="true" VBox.vgrow="NEVER" prefHeight="300">
        <HBox spacing="15" styleClass="charts-container">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- 班次收入对比柱状图 -->
            <VBox spacing="5" styleClass="chart-card" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <Label text="%shift.revenue_chart" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
                <BarChart fx:id="shiftRevenueBarChart" prefHeight="250">
                    <xAxis>
                        <CategoryAxis label="%shift.shift_axis"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="%shift.revenue_axis"/>
                    </yAxis>
                </BarChart>
            </VBox>

            <!-- 支付方式分布饼图 -->
            <VBox spacing="5" styleClass="chart-card" prefWidth="400">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <Label text="%shift.payment_chart" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                <PieChart fx:id="paymentMethodPieChart" prefWidth="380" prefHeight="250" legendSide="RIGHT"/>
            </VBox>
        </HBox>
    </ScrollPane>

    <!-- 交接班记录表格 -->
    <TableView fx:id="shiftTable"
              VBox.vgrow="ALWAYS"
              styleClass="shift-table">
        <columns>
            <TableColumn fx:id="shiftIdColumn" text="%shift.shift_id" prefWidth="150"/>
            <TableColumn fx:id="operatorColumn" text="%shift.operator" prefWidth="120"/>
            <TableColumn fx:id="timeColumn" text="%shift.time" prefWidth="160"/>
            <TableColumn fx:id="durationColumn" text="%shift.duration" prefWidth="100"/>
            <TableColumn fx:id="transactionColumn" text="%shift.transaction_count" prefWidth="80"/>
            <TableColumn fx:id="revenueColumn" text="%shift.revenue" prefWidth="100"/>
            <TableColumn fx:id="paymentColumn" text="%shift.payment_methods" prefWidth="300"/>
        </columns>
        <placeholder>
            <Label text="%shift.no_data" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>