<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.CartController"
      spacing="0"
      styleClass="cart-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="12" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="12" right="12" bottom="12" left="12"/>
        </padding>

        <!-- 搜索框放在最前面，方便快速输入 -->
        <HBox spacing="8" alignment="CENTER_LEFT" styleClass="search-section">
            <Label text="%cart.search_products" styleClass="search-label"/>
            <TextField fx:id="searchField"
                      promptText="%cart.scan_or_search"
                      styleClass="search-field-input"/>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 统计信息 -->
        <Label fx:id="countLabel" text="%cart.product_count" styleClass="count-label"/>

        <Separator orientation="VERTICAL" styleClass="toolbar-separator"/>

        <!-- 操作按钮 -->
        <Button fx:id="clearButton"
                text="%cart.clear"
                onAction="#handleClearCart"
                styleClass="warning-button, button-action"/>

        <Button text="%cart.shortcut_help"
                onAction="#showShortcutHelp"
                styleClass="info-button, button-action"/>
    </HBox>

    <!-- 分割面板 -->
    <SplitPane VBox.vgrow="ALWAYS" styleClass="cart-split-pane">
        <!-- 左侧：购物车商品列表 -->
        <VBox VBox.vgrow="ALWAYS" styleClass="cart-section">
            <!-- 区域标题 -->
            <Label text="%cart.title_with_icon" styleClass="section-header"/>

            <TableView fx:id="cartTable"
                      VBox.vgrow="ALWAYS"
                      styleClass="cart-table">
                <columns>
                    <TableColumn fx:id="nameColumn" text="%cart.product_name"/>
                    <TableColumn fx:id="priceColumn" text="%cart.unit_price"/>
                    <TableColumn fx:id="quantityColumn" text="%cart.quantity"/>
                    <TableColumn fx:id="subtotalColumn" text="%cart.subtotal"/>
                </columns>
                <placeholder>
                    <Label text="%cart.empty" styleClass="empty-label"/>
                </placeholder>
            </TableView>
        </VBox>

        <!-- 右侧：商品列表和结算信息 -->
        <VBox spacing="0">
            <!-- 商品列表区域 -->
            <VBox VBox.vgrow="ALWAYS" spacing="0">
                <!-- 商品列表标题 -->
                <HBox styleClass="section-header" alignment="CENTER_LEFT">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <Label text="%cart.available_products" styleClass="product-list-title"/>
                    <Label text="%cart.double_click_add" styleClass="double-click-hint"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="%cart.stock" styleClass="stock-hint"/>
                </HBox>

                <TableView fx:id="productTable"
                          VBox.vgrow="ALWAYS"
                          styleClass="product-table">
                    <columns>
                        <TableColumn fx:id="productNameColumn" text="%cart.product_name"/>
                        <TableColumn fx:id="productPriceColumn" text="%cart.unit_price"/>
                        <TableColumn fx:id="productStockColumn" text="%cart.stock"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- 结算信息区域 -->
            <VBox spacing="8" styleClass="checkout-info">
                <padding>
                    <Insets top="12" right="12" bottom="12" left="12"/>
                </padding>

                <!-- 会员信息 -->
                <VBox spacing="8" styleClass="member-info-box">
                    <padding>
                        <Insets top="8" right="8" bottom="8" left="8"/>
                    </padding>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="%cart.member_phone" styleClass="member-label"/>
                        <TextField fx:id="memberPhoneField" promptText="%cart.enter_phone" styleClass="member-phone-input"/>
                        <Button text="%cart.search_button" onAction="#handleSearchMember" styleClass="secondary-button, button-small"/>
                    </HBox>
                    <Label fx:id="memberInfoLabel" text="" styleClass="member-info-display"/>
                </VBox>

                <Separator/>

                <!-- 金额信息 -->
                <VBox spacing="6" styleClass="amount-info">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="%cart.total_quantity" styleClass="amount-label"/>
                        <Label fx:id="totalQuantityLabel" text="0" styleClass="amount-value"/>
                    </HBox>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="%cart.total_amount" styleClass="amount-label"/>
                        <Label fx:id="totalAmountLabel" text="¥0.00" styleClass="amount-value"/>
                    </HBox>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="%cart.member_discount" styleClass="amount-label"/>
                        <Label fx:id="memberDiscountLabel" text="0%" styleClass="discount-value"/>
                    </HBox>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="%cart.discount_amount" styleClass="amount-label"/>
                        <Label fx:id="discountLabel" text="-¥0.00" styleClass="discount-value"/>
                    </HBox>

                    <Separator/>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="%cart.final_amount" styleClass="final-label"/>
                        <Label fx:id="finalAmountLabel" text="¥0.00" styleClass="final-value"/>
                    </HBox>
                </VBox>

                <!-- 支付方式 -->
                <VBox spacing="8">
                    <padding>
                        <Insets top="10" right="0" bottom="5" left="0"/>
                    </padding>
                    <Label text="%cart.payment_method" styleClass="payment-method-label"/>
                    <GridPane hgap="8" vgap="8" styleClass="payment-grid">
                        <Button fx:id="cashButton"
                                text="%cart.cash_payment"
                                onAction="#handleCashPayment"
                                styleClass="payment-button cash-button"
                                GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Button fx:id="wechatButton"
                                text="%cart.wechat_payment"
                                onAction="#handleWechatPayment"
                                styleClass="payment-button wechat-button"
                                GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Button fx:id="alipayButton"
                                text="%cart.alipay_payment"
                                onAction="#handleAlipayPayment"
                                styleClass="payment-button alipay-button"
                                GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Button fx:id="cardButton"
                                text="%cart.card_payment"
                                onAction="#handleCardPayment"
                                styleClass="payment-button card-button"
                                GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    </GridPane>
                </VBox>
            </VBox>
        </VBox>
    </SplitPane>

</VBox>
