<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.PurchaseApprovalController"
      spacing="0"
      styleClass="purchase-approval-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 操作按钮 -->
        <Button fx:id="approveButton"
                text="%purchase_approval.approve"
                onAction="#handleApprove"
                prefWidth="100"
                disable="true"
                styleClass="success-button"/>

        <Button fx:id="rejectButton"
                text="%purchase_approval.reject"
                onAction="#handleReject"
                prefWidth="100"
                disable="true"
                styleClass="danger-button"/>

        <Button fx:id="viewDetailButton"
                text="%purchase_approval.view_detail"
                onAction="#handleViewDetail"
                prefWidth="100"
                disable="true"
                styleClass="info-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 搜索 -->
        <Label text="%purchase_approval.search_label"/>
        <TextField fx:id="searchField"
                  promptText="%purchase_approval.search_hint"
                  prefWidth="200"
                  onAction="#handleSearch"/>

        <Button text="%purchase_approval.search"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button text="%purchase_approval.refresh"
                onAction="#handleRefresh"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 统计信息 -->
        <Label fx:id="countLabel" text="%purchase_approval.current_display" style="-fx-text-fill: #757575;"/>
        <Label fx:id="pendingCountLabel" text="%purchase_approval.pending_count" style="-fx-text-fill: #f44336; -fx-font-weight: bold;"/>
    </HBox>

    <!-- 待审批订单表格 -->
    <TableView fx:id="orderTable"
              VBox.vgrow="ALWAYS"
              styleClass="purchase-approval-table">
        <columns>
            <TableColumn fx:id="orderNoColumn" text="%purchase_approval.order_no" prefWidth="150"/>
            <TableColumn fx:id="supplierColumn" text="%purchase_approval.supplier" prefWidth="200"/>
            <TableColumn fx:id="purchaseDateColumn" text="%purchase_approval.purchase_date" prefWidth="100"/>
            <TableColumn fx:id="totalAmountColumn" text="%purchase_approval.total_amount" prefWidth="100"/>
            <TableColumn fx:id="purchaserColumn" text="%purchase_approval.purchaser" prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="%purchase_approval.no_data" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>