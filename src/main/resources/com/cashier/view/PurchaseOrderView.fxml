<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.PurchaseOrderController"
      spacing="0"
      styleClass="purchase-order-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 操作按钮 -->
        <Button fx:id="addButton"
                text="新建订单"
                onAction="#handleAddOrder"
                prefWidth="100"
                styleClass="primary-button"/>

        <Button fx:id="editButton"
                text="编辑"
                onAction="#handleEditOrder"
                prefWidth="80"
                disable="true"
                styleClass="secondary-button"/>

        <Button fx:id="deleteButton"
                text="删除"
                onAction="#handleDeleteOrder"
                prefWidth="80"
                disable="true"
                styleClass="danger-button"/>

        <Button fx:id="viewDetailButton"
                text="查看详情"
                onAction="#handleViewDetail"
                prefWidth="100"
                disable="true"
                styleClass="info-button"/>

        <Button fx:id="submitApprovalButton"
                text="提交审批"
                onAction="#handleSubmitApproval"
                prefWidth="100"
                disable="true"
                styleClass="success-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 筛选 -->
        <Label text="状态:"/>
        <ComboBox fx:id="statusFilterCombo"
                  prefWidth="100"
                  onAction="#handleStatusFilter"/>

        <Separator orientation="VERTICAL"/>

        <!-- 搜索 -->
        <Label text="搜索:"/>
        <TextField fx:id="searchField"
                  promptText="输入订单号或供应商"
                  prefWidth="200"
                  onAction="#handleSearch"/>

        <Button text="搜索"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 统计信息 -->
        <Label fx:id="countLabel" text="订单数量: 0" style="-fx-text-fill: #757575;"/>
    </HBox>

    <!-- 采购订单表格 -->
    <TableView fx:id="orderTable"
              VBox.vgrow="ALWAYS"
              styleClass="purchase-order-table">
        <columns>
            <TableColumn fx:id="orderNoColumn" text="订单号" prefWidth="150"/>
            <TableColumn fx:id="supplierColumn" text="供应商" prefWidth="150"/>
            <TableColumn fx:id="purchaseDateColumn" text="采购日期" prefWidth="100"/>
            <TableColumn fx:id="totalAmountColumn" text="总金额(元)" prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="状态" prefWidth="80"/>
            <TableColumn fx:id="purchaserColumn" text="采购人" prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="暂无采购订单数据" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>