<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.PurchaseOrderController"
      spacing="0"
      styleClass="purchase-order-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 操作按钮 -->
        <Button fx:id="addButton"
                text="%purchase_order.add"
                onAction="#handleAddOrder"
                prefWidth="100"
                styleClass="primary-button"/>

        <Button fx:id="editButton"
                text="%purchase_order.edit"
                onAction="#handleEditOrder"
                prefWidth="80"
                disable="true"
                styleClass="secondary-button"/>

        <Button fx:id="deleteButton"
                text="%purchase_order.delete"
                onAction="#handleDeleteOrder"
                prefWidth="80"
                disable="true"
                styleClass="danger-button"/>

        <Button fx:id="viewDetailButton"
                text="%purchase_order.view_detail"
                onAction="#handleViewDetail"
                prefWidth="100"
                disable="true"
                styleClass="info-button"/>

        <Button fx:id="submitApprovalButton"
                text="%purchase_order.submit_approval"
                onAction="#handleSubmitApproval"
                prefWidth="100"
                disable="true"
                styleClass="success-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 筛选 -->
        <Label text="%purchase_order.status_label"/>
        <ComboBox fx:id="statusFilterCombo"
                  prefWidth="100"
                  onAction="#handleStatusFilter"/>

        <Separator orientation="VERTICAL"/>

        <!-- 搜索 -->
        <Label text="%purchase_order.search_label"/>
        <TextField fx:id="searchField"
                  promptText="%purchase_order.search_hint"
                  prefWidth="200"
                  onAction="#handleSearch"/>

        <Button text="%common.search"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 统计信息 -->
        <Label fx:id="countLabel" text="%purchase_order.count" style="-fx-text-fill: #757575;"/>
    </HBox>

    <!-- 采购订单表格 -->
    <TableView fx:id="orderTable"
              VBox.vgrow="ALWAYS"
              styleClass="purchase-order-table">
        <columns>
            <TableColumn fx:id="orderNoColumn" text="%purchase_order.order_no" prefWidth="150"/>
            <TableColumn fx:id="supplierColumn" text="%purchase_order.supplier" prefWidth="200"/>
            <TableColumn fx:id="purchaseDateColumn" text="%purchase_order.purchase_date" prefWidth="100"/>
            <TableColumn fx:id="totalAmountColumn" text="%purchase_order.total_amount" prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="%purchase_order.status" prefWidth="80"/>
            <TableColumn fx:id="purchaserColumn" text="%purchase_order.purchaser" prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="%purchase_order.no_data" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>
