<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.CreateReturnOrderDialogController"
      spacing="15"
      styleClass="dialog-container">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- 标题 -->
    <Label text="%return_order.title" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- 原交易信息 -->
    <VBox spacing="5" style="-fx-background-color: #f5f5f5; -fx-padding: 10;">
        <Label text="%return_order.original_info" style="-fx-font-weight: bold;"/>
        <GridPane hgap="10" vgap="5">
            <Label text="%return_order.transaction_id" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label fx:id="transactionIdLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-text-fill: blue;"/>

            <Label text="%return_order.transaction_amount" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <Label fx:id="transactionAmountLabel" GridPane.columnIndex="3" GridPane.rowIndex="0"
                   style="-fx-text-fill: red; -fx-font-weight: bold;"/>

            <Label text="%return_order.transaction_date" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Label fx:id="transactionDateLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="%return_order.payment_method" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <Label fx:id="paymentMethodLabel" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

            <Label text="%return_order.member" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Label fx:id="memberNameLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>
    </VBox>

    <!-- 退货商品列表 -->
    <VBox spacing="5" VBox.vgrow="ALWAYS">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="%return_order.items" style="-fx-font-weight: bold;"/>
            <CheckBox fx:id="selectAllCheckBox" text="%return_order.select_all" onAction="#handleSelectAll"/>
        </HBox>
        <TableView fx:id="returnItemTable" VBox.vgrow="ALWAYS" prefHeight="250">
            <columns>
                <TableColumn fx:id="selectColumn" text="%return_order.select" prefWidth="60" editable="true"/>
                <TableColumn fx:id="productCodeColumn" text="%return_order.product_code" prefWidth="100"/>
                <TableColumn fx:id="productNameColumn" text="%return_order.product_name" prefWidth="150"/>
                <TableColumn fx:id="originalQuantityColumn" text="%return_order.original_quantity" prefWidth="80"/>
                <TableColumn fx:id="returnQuantityColumn" text="%return_order.return_quantity" prefWidth="100" editable="true"/>
                <TableColumn fx:id="unitPriceColumn" text="%return_order.unit_price" prefWidth="80"/>
                <TableColumn fx:id="returnAmountColumn" text="%return_order.return_amount" prefWidth="100"/>
                <TableColumn fx:id="conditionColumn" text="%return_order.condition" prefWidth="100" editable="true"/>
                <TableColumn fx:id="reasonColumn" text="%return_order.reason" prefWidth="150" editable="true"/>
            </columns>
        </TableView>
    </VBox>

    <!-- 退货信息 -->
    <VBox spacing="10">
        <Label text="%return_order.return_info" style="-fx-font-weight: bold;"/>
        <GridPane hgap="10" vgap="5">
            <Label text="%return_order.return_reason_label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="returnReasonField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                      prefWidth="300" promptText="%return_order.return_reason_hint"/>

            <Label text="%return_order.refund_method" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="refundMethodComboBox" GridPane.columnIndex="1" GridPane.rowIndex="1"
                     prefWidth="150"/>
        </GridPane>

        <VBox spacing="5">
            <Label text="%return_order.notes"/>
            <TextArea fx:id="notesArea" prefRowCount="2" promptText="%return_order.notes_hint" wrapText="true"/>
        </VBox>
    </VBox>

    <!-- 退货金额汇总 -->
    <HBox spacing="20" alignment="CENTER_RIGHT" style="-fx-background-color: #f0f0f0; -fx-padding: 10;">
        <Label text="%return_order.total_amount" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <Label fx:id="totalReturnAmountLabel" text="¥0.00"
              style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: red;"/>
    </HBox>

    <!-- 按钮区域 -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="%return_order.cancel" onAction="#handleCancel" prefWidth="100"/>
        <Button text="%return_order.submit" onAction="#handleSubmit" styleClass="primary-button" prefWidth="100"/>
    </HBox>
</VBox>
