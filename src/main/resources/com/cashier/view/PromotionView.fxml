<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.PromotionController"
      spacing="0"
      styleClass="promotion-view">

    <!-- 顶部工具栏 -->
    <VBox spacing="5" styleClass="toolbar">
        <!-- 第一行：操作按钮 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="5" left="10"/>
            </padding>

            <Button fx:id="addButton"
                    text="%promotion.add"
                    onAction="#handleAddPromotion"
                    prefWidth="100"
                    styleClass="primary-button"/>

            <Button fx:id="editButton"
                    text="%promotion.edit"
                    onAction="#handleEditPromotion"
                    prefWidth="80"
                    styleClass="secondary-button"/>

            <Button fx:id="deleteButton"
                    text="%promotion.delete"
                    onAction="#handleDeletePromotion"
                    prefWidth="80"
                    styleClass="danger-button"/>

            <Button fx:id="enableButton"
                    text="%promotion.enable"
                    onAction="#handleEnablePromotion"
                    prefWidth="80"
                    styleClass="success-button"/>

            <Button fx:id="disableButton"
                    text="%promotion.disable"
                    onAction="#handleDisablePromotion"
                    prefWidth="80"
                    styleClass="warning-button"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="countLabel" text="%promotion.count" style="-fx-text-fill: #757575;"/>
        </HBox>

        <!-- 第二行：筛选和搜索 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="5" right="10" bottom="10" left="10"/>
            </padding>

            <Label text="%promotion.type_label"/>
            <ComboBox fx:id="typeFilterComboBox" prefWidth="100"/>

            <Label text="%promotion.status_label"/>
            <ComboBox fx:id="statusFilterComboBox" prefWidth="100"/>

            <Separator orientation="VERTICAL"/>

            <Label text="%promotion.search_label"/>
            <TextField fx:id="searchField"
                      promptText="%promotion.search_hint"
                      prefWidth="200"
                      onAction="#handleSearch"/>

            <Button text="%common.search"
                    onAction="#handleSearch"
                    prefWidth="60"
                    styleClass="secondary-button"/>

            <Button text="%common.clear"
                    onAction="#handleClearSearch"
                    prefWidth="60"
                    styleClass="secondary-button"/>
        </HBox>
    </VBox>

    <!-- 促销列表表格 -->
    <TableView fx:id="promotionTable"
              VBox.vgrow="ALWAYS"
              styleClass="promotion-table">
        <columns>
            <TableColumn fx:id="nameColumn" text="%promotion.name" prefWidth="150"/>
            <TableColumn fx:id="typeColumn" text="%promotion.type" prefWidth="80"/>
            <TableColumn fx:id="descriptionColumn" text="%promotion.description" prefWidth="250"/>
            <TableColumn fx:id="periodColumn" text="%promotion.period" prefWidth="180"/>
            <TableColumn fx:id="usageColumn" text="%promotion.usage" prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="%promotion.status" prefWidth="120"/>
        </columns>
        <placeholder>
            <Label text="%promotion.no_data" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>
