<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.RestockController"
      spacing="12"
      styleClass="restock-view"
      prefWidth="450"
      prefHeight="380">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- 标题 -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="titleLabel"
               text="快速入库"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="快速入库通道" style="-fx-font-size: 12px; -fx-text-fill: #757575; -fx-font-style: italic;"/>
    </HBox>

    <!-- 商品信息卡片 -->
    <VBox spacing="8" styleClass="product-info-card">
        <padding>
            <Insets top="12" right="15" bottom="12" left="15"/>
        </padding>
        <Label fx:id="productLabel" text="" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #212121;"/>
        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label fx:id="currentStockLabel" text="" style="-fx-font-size: 13px; -fx-text-fill: #757575;"/>
            <Label fx:id="costPriceLabel" text="" style="-fx-font-size: 13px; -fx-text-fill: #757575;"/>
        </HBox>
    </VBox>

    <!-- 表单 -->
    <GridPane hgap="15" vgap="12">
        <padding>
            <Insets top="5" right="0" bottom="5" left="0"/>
        </padding>
        <columnConstraints>
            <ColumnConstraints hgrow="NEVER" minWidth="80"/>
            <ColumnConstraints hgrow="SOMETIMES" prefWidth="250"/>
        </columnConstraints>

        <!-- 补货数量 -->
        <Label text="入库数量:" GridPane.columnIndex="0" GridPane.rowIndex="0"
               style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #424242;"/>
        <TextField fx:id="quantityField"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"
                   prefWidth="250" promptText="输入入库数量"
                   style="-fx-font-size: 14px;"/>

        <!-- 入库来源 -->
        <Label text="入库来源:" GridPane.columnIndex="0" GridPane.rowIndex="1"
               style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #424242;"/>
        <ComboBox fx:id="sourceComboBox"
                  GridPane.columnIndex="1" GridPane.rowIndex="1"
                  prefWidth="250" editable="true"
                  style="-fx-font-size: 14px;"/>

        <!-- 备注 -->
        <Label text="备注:" GridPane.columnIndex="0" GridPane.rowIndex="2"
               style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #424242;"/>
        <TextField fx:id="reasonField"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"
                   prefWidth="250" promptText="可选，如供应商名称"
                   style="-fx-font-size: 14px;"/>
    </GridPane>

    <!-- 实时预览信息 -->
    <VBox spacing="8" styleClass="preview-box">
        <padding>
            <Insets top="10" right="15" bottom="10" left="15"/>
        </padding>
        <Label text="入库预览" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #757575;"/>
        <HBox spacing="30" alignment="CENTER_LEFT">
            <VBox spacing="2">
                <Label text="入库后库存" style="-fx-font-size: 11px; -fx-text-fill: #9E9E9E;"/>
                <Label fx:id="afterStockLabel" text="-" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
            </VBox>
            <VBox spacing="2">
                <Label text="入库金额" style="-fx-font-size: 11px; -fx-text-fill: #9E9E9E;"/>
                <Label fx:id="totalCostLabel" text="-" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #F57C00;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- 错误提示 -->
    <Label fx:id="errorLabel"
           text=""
           style="-fx-text-fill: #F44336; -fx-font-size: 12px;"/>

    <!-- 按钮区域 -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="cancelButton"
                text="取消"
                onAction="#handleCancel"
                prefWidth="90"
                prefHeight="38"
                styleClass="secondary-button"/>
        <Button fx:id="confirmButton"
                text="确认入库"
                onAction="#handleConfirm"
                prefWidth="90"
                prefHeight="38"
                styleClass="primary-button"/>
    </HBox>

</VBox>