<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.InventoryController"
      spacing="0"
      styleClass="inventory-view">

    <!-- 顶部工具栏 -->
    <VBox spacing="5" styleClass="toolbar">
        <!-- 第一行：操作按钮 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="5" left="10"/>
            </padding>

            <Button fx:id="addButton"
                    text="%product.add"
                    onAction="#handleAddProduct"
                    prefWidth="100"
                    styleClass="primary-button"/>

            <Button fx:id="editButton"
                    text="%product.edit"
                    onAction="#handleEditProduct"
                    prefWidth="80"
                    styleClass="secondary-button"/>

            <Button fx:id="deleteButton"
                    text="%product.delete"
                    onAction="#handleDeleteProduct"
                    prefWidth="80"
                    styleClass="danger-button"/>

            <Button fx:id="restockButton"
                    text="%inventory.restock"
                    onAction="#handleRestock"
                    prefWidth="80"
                    styleClass="info-button"/>

            <Button fx:id="categoryButton"
                    text="%inventory.category_management"
                    onAction="#handleCategoryManagement"
                    prefWidth="100"
                    styleClass="secondary-button"/>

            <Button fx:id="unitButton"
                    text="%inventory.unit_management"
                    onAction="#handleUnitManagement"
                    prefWidth="100"
                    styleClass="secondary-button"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="countLabel" text="%inventory.count" style="-fx-text-fill: #757575;"/>
        </HBox>

        <!-- 第二行：搜索和排序 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="5" right="10" bottom="10" left="10"/>
            </padding>

            <Label text="%inventory.search_label"/>
            <TextField fx:id="searchField"
                      promptText="%inventory.search_hint"
                      prefWidth="200"
                      onAction="#handleSearch"/>

            <Button text="%inventory.search_button"
                    onAction="#handleSearch"
                    prefWidth="60"
                    styleClass="secondary-button"/>

            <Button text="%inventory.clear_button"
                    onAction="#handleClearSearch"
                    prefWidth="60"
                    styleClass="secondary-button"/>

            <Button text="%inventory.refresh_button"
                    onAction="#handleRefresh"
                    prefWidth="60"
                    styleClass="success-button"/>

            <Separator orientation="VERTICAL"/>

            <Label text="%inventory.sort_label"/>
            <ComboBox fx:id="sortComboBox" prefWidth="150"/>
        </HBox>
    </VBox>

    <!-- 商品表格 -->
    <TableView fx:id="inventoryTable"
              VBox.vgrow="ALWAYS"
              styleClass="inventory-table">
        <columns>
            <TableColumn fx:id="barcodeColumn" text="%inventory.barcode" prefWidth="130"/>
            <TableColumn fx:id="nameColumn" text="%product.name" prefWidth="220"/>
            <TableColumn fx:id="priceColumn" text="%cart.unit_price" prefWidth="90"/>
            <TableColumn fx:id="quantityColumn" text="%product.stock" prefWidth="70"/>
            <TableColumn fx:id="minStockColumn" text="%inventory.min_stock" prefWidth="70"/>
            <TableColumn fx:id="categoryColumn" text="%product.category" prefWidth="100"/>
            <TableColumn fx:id="warningColumn" text="%inventory.warning_status" prefWidth="80"/>
        </columns>
        <placeholder>
            <Label text="%inventory.no_data" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>
