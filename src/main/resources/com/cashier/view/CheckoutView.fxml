<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.CheckoutController"
      spacing="0"
      styleClass="checkout-view">

    <!-- 顶部信息栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <Label text="结账" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="orderNumberLabel" text="订单号: " style="-fx-font-size: 13px; -fx-text-fill: #757575;"/>
        <Label fx:id="cashierLabel" text="收银员: " style="-fx-font-size: 13px; -fx-text-fill: #757575;"/>

        <Separator orientation="VERTICAL"/>

        <!-- 快捷键帮助按钮 -->
        <Button text="快捷键 (Ctrl+/)"
                onAction="#showShortcutHelp"
                prefWidth="140"
                prefHeight="35"
                style="-fx-font-size: 13px; -fx-font-weight: bold;"
                styleClass="secondary-button"/>
    </HBox>

    <!-- 分割面板 -->
    <SplitPane VBox.vgrow="ALWAYS" styleClass="checkout-split-pane">
        <!-- 左侧：商品列表 -->
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <TableView fx:id="cartTable" VBox.vgrow="ALWAYS" styleClass="cart-table">
                <columns>
                    <TableColumn fx:id="nameColumn" text="商品名称" prefWidth="200"/>
                    <TableColumn fx:id="priceColumn" text="单价(元)" prefWidth="100"/>
                    <TableColumn fx:id="quantityColumn" text="数量" prefWidth="100"/>
                    <TableColumn fx:id="subtotalColumn" text="小计(元)" prefWidth="100"/>
                </columns>
            </TableView>

            <!-- 会员信息 -->
            <VBox spacing="5" styleClass="member-info-box">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="会员手机号 (Ctrl+M):" style="-fx-font-size: 13px; -fx-text-fill: #424242;"/>
                    <TextField fx:id="memberPhoneField" prefWidth="150" promptText="输入手机号"/>
                    <Button text="查询" onAction="#handleSearchMember" prefWidth="70" prefHeight="35" style="-fx-font-size: 13px; -fx-font-weight: bold;" styleClass="secondary-button"/>
                </HBox>
                <Label fx:id="memberInfoLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #4CAF50;"/>
            </VBox>
        </VBox>

        <!-- 右侧：支付信息 -->
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- 商品统计 -->
            <VBox spacing="5" styleClass="checkout-info">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="商品总数:" style="-fx-font-size: 13px;"/>
                    <Label fx:id="totalQuantityLabel" text="0" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="商品金额:" style="-fx-font-size: 13px;"/>
                    <Label fx:id="totalAmountLabel" text="¥0.00" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="会员折扣:" style="-fx-font-size: 13px;"/>
                    <Label fx:id="memberDiscountLabel" text="0%" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="折扣金额:" style="-fx-font-size: 13px;"/>
                    <Label fx:id="discountLabel" text="-¥0.00" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                </HBox>

                <Separator/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="应付金额:" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label fx:id="finalAmountLabel" text="¥0.00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #F44336;"/>
                </HBox>
            </VBox>

            <!-- 支付方式 -->
            <VBox spacing="10" styleClass="payment-methods">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <Label text="支付方式" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>

                <VBox spacing="8">
                    <Button fx:id="cashButton"
                            text="现金支付 (F8)"
                            onAction="#handleCashPayment"
                            prefWidth="160"
                            prefHeight="50"
                            style="-fx-font-size: 14px; -fx-font-weight: bold;"
                            styleClass="payment-button, cash-button"/>

                    <Button fx:id="wechatButton"
                            text="微信支付 (Ctrl+1)"
                            onAction="#handleWechatPayment"
                            prefWidth="160"
                            prefHeight="50"
                            style="-fx-font-size: 14px; -fx-font-weight: bold;"
                            styleClass="payment-button, wechat-button"/>

                    <Button fx:id="alipayButton"
                            text="支付宝 (Ctrl+2)"
                            onAction="#handleAlipayPayment"
                            prefWidth="160"
                            prefHeight="50"
                            style="-fx-font-size: 14px; -fx-font-weight: bold;"
                            styleClass="payment-button, alipay-button"/>

                    <Button fx:id="cardButton"
                            text="银行卡 (Ctrl+3)"
                            onAction="#handleCardPayment"
                            prefWidth="160"
                            prefHeight="50"
                            style="-fx-font-size: 14px; -fx-font-weight: bold;"
                            styleClass="payment-button, card-button"/>
                </VBox>
            </VBox>

            <!-- 操作按钮 -->
            <VBox spacing="10" styleClass="checkout-actions">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <Button fx:id="cancelButton"
                        text="取消 (Esc)"
                        onAction="#handleCancel"
                        prefWidth="170"
                        prefHeight="45"
                        style="-fx-font-size: 14px; -fx-font-weight: bold;"
                        styleClass="secondary-button"/>

                <Button fx:id="printButton"
                        text="打印小票"
                        onAction="#handlePrint"
                        prefWidth="170"
                        prefHeight="45"
                        style="-fx-font-size: 14px; -fx-font-weight: bold;"
                        styleClass="info-button"
                        disable="true"/>
            </VBox>
        </VBox>
    </SplitPane>

</VBox>