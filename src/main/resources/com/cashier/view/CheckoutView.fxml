<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.CheckoutController"
      spacing="0"
      styleClass="checkout-view">

    <!-- 顶部信息栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <Label text="%checkout.title" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="orderNumberLabel" text="%checkout.order_number" style="-fx-font-size: 13px; -fx-text-fill: #757575;"/>
        <Label fx:id="cashierLabel" text="%checkout.cashier" style="-fx-font-size: 13px; -fx-text-fill: #757575;"/>

        <Separator orientation="VERTICAL"/>

        <!-- 快捷键帮助按钮 -->
        <Button text="%checkout.shortcut_help"
                onAction="#showShortcutHelp"
                prefWidth="140"
                prefHeight="35"
                style="-fx-font-size: 13px; -fx-font-weight: bold;"
                styleClass="secondary-button"/>
    </HBox>

    <!-- 分割面板 -->
    <SplitPane VBox.vgrow="ALWAYS" styleClass="checkout-split-pane">
        <!-- 左侧：商品列表 -->
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <TableView fx:id="cartTable" VBox.vgrow="ALWAYS" styleClass="cart-table">
                <columns>
                    <TableColumn fx:id="nameColumn" text="%cart.product_name" prefWidth="200"/>
                    <TableColumn fx:id="priceColumn" text="%cart.unit_price" prefWidth="100"/>
                    <TableColumn fx:id="quantityColumn" text="%cart.quantity" prefWidth="100"/>
                    <TableColumn fx:id="subtotalColumn" text="%cart.subtotal" prefWidth="100"/>
                </columns>
            </TableView>

            <!-- 会员信息 -->
            <VBox spacing="5" styleClass="member-info-box">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="%cart.member_phone" style="-fx-font-size: 13px; -fx-text-fill: #424242;"/>
                    <TextField fx:id="memberPhoneField" prefWidth="150" promptText="%cart.enter_phone"/>
                    <Button text="%cart.search_button" onAction="#handleSearchMember" prefWidth="70" prefHeight="35" style="-fx-font-size: 13px; -fx-font-weight: bold;" styleClass="secondary-button"/>
                </HBox>
                <Label fx:id="memberInfoLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #4CAF50;"/>
            </VBox>
        </VBox>

        <!-- 右侧：支付信息 -->
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- 商品统计 -->
            <VBox spacing="5" styleClass="checkout-info">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="%cart.total_quantity" style="-fx-font-size: 13px;"/>
                    <Label fx:id="totalQuantityLabel" text="0" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="%cart.total_amount" style="-fx-font-size: 13px;"/>
                    <Label fx:id="totalAmountLabel" text="¥0.00" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="%cart.member_discount" style="-fx-font-size: 13px;"/>
                    <Label fx:id="memberDiscountLabel" text="0%" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                </HBox>

                <!-- 优惠券输入区域 -->
                <VBox spacing="5" styleClass="coupon-section">
                    <padding>
                        <Insets top="5" right="0" bottom="5" left="0"/>
                    </padding>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="%checkout.coupon_code" style="-fx-font-size: 13px; -fx-text-fill: #424242;"/>
                        <TextField fx:id="couponCodeField"
                                    prefWidth="150"
                                    promptText="%checkout.enter_coupon"
                                    onAction="#handleVerifyCoupon"/>
                        <Button fx:id="verifyCouponButton"
                                text="%checkout.verify"
                                onAction="#handleVerifyCoupon"
                                prefWidth="70"
                                prefHeight="30"
                                style="-fx-font-size: 12px; -fx-font-weight: bold;"
                                styleClass="secondary-button"/>
                        <Button fx:id="clearCouponButton"
                                text="%checkout.clear"
                                onAction="#handleClearCoupon"
                                prefWidth="70"
                                prefHeight="30"
                                style="-fx-font-size: 12px;"
                                styleClass="warning-button"
                                disable="true"/>
                    </HBox>
                    <Label fx:id="couponInfoLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #4CAF50;"/>
                </VBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="%cart.discount_amount" style="-fx-font-size: 13px;"/>
                    <Label fx:id="discountLabel" text="-¥0.00" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                </HBox>

                <Separator/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="%cart.final_amount" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label fx:id="finalAmountLabel" text="¥0.00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #F44336;"/>
                </HBox>
            </VBox>

            <!-- 支付方式 -->
            <VBox spacing="10" styleClass="payment-methods">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <Label text="%checkout.payment_method_label" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>

                <VBox spacing="8">
                    <Button fx:id="cashButton"
                            text="%cart.cash_payment"
                            onAction="#handleCashPayment"
                            prefWidth="160"
                            prefHeight="50"
                            style="-fx-font-size: 14px; -fx-font-weight: bold;"
                            styleClass="payment-button, cash-button"/>

                    <Button fx:id="wechatButton"
                            text="%cart.wechat_payment"
                            onAction="#handleWechatPayment"
                            prefWidth="160"
                            prefHeight="50"
                            style="-fx-font-size: 14px; -fx-font-weight: bold;"
                            styleClass="payment-button, wechat-button"/>

                    <Button fx:id="alipayButton"
                            text="%cart.alipay_payment"
                            onAction="#handleAlipayPayment"
                            prefWidth="160"
                            prefHeight="50"
                            style="-fx-font-size: 14px; -fx-font-weight: bold;"
                            styleClass="payment-button, alipay-button"/>

                    <Button fx:id="cardButton"
                            text="%cart.card_payment"
                            onAction="#handleCardPayment"
                            prefWidth="160"
                            prefHeight="50"
                            style="-fx-font-size: 14px; -fx-font-weight: bold;"
                            styleClass="payment-button, card-button"/>
                </VBox>
            </VBox>

            <!-- 操作按钮 -->
            <VBox spacing="10" styleClass="checkout-actions">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <Button fx:id="cancelButton"
                        text="%checkout.cancel"
                        onAction="#handleCancel"
                        prefWidth="170"
                        prefHeight="45"
                        style="-fx-font-size: 14px; -fx-font-weight: bold;"
                        styleClass="secondary-button"/>

                <Button fx:id="printButton"
                        text="%checkout.print_receipt"
                        onAction="#handlePrint"
                        prefWidth="170"
                        prefHeight="45"
                        style="-fx-font-size: 14px; -fx-font-weight: bold;"
                        styleClass="info-button"
                        disable="true"/>
            </VBox>
        </VBox>
    </SplitPane>

</VBox>
