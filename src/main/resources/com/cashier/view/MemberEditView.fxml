<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.MemberEditController"
      spacing="15"
      styleClass="member-edit-view"
      prefWidth="550"
      prefHeight="500">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- 标题 -->
    <Label fx:id="titleLabel" 
           text="添加会员" 
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>

    <!-- 表单 -->
    <GridPane hgap="15" vgap="15" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="15" right="10" bottom="30" left="10"/>
        </padding>
        <!-- 列宽设置：标签列固定宽度，输入框列固定宽度 -->
        <columnConstraints>
            <ColumnConstraints prefWidth="90" minWidth="90" maxWidth="90"/>
            <ColumnConstraints prefWidth="150" hgrow="NEVER"/>
            <ColumnConstraints prefWidth="90" minWidth="90" maxWidth="90"/>
            <ColumnConstraints prefWidth="150" hgrow="NEVER"/>
        </columnConstraints>

        <!-- 会员编号和自动生成复选框 -->
        <Label text="会员编号:*" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.columnSpan="3">
            <TextField fx:id="memberCodeField"
                       prefWidth="150" promptText="留空则自动生成"/>
            <CheckBox fx:id="autoCodeCheckBox"
                      text="自动生成"/>
        </HBox>

        <!-- 手机号 -->
        <Label text="手机号:*" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="phoneField"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"
                   prefWidth="150" promptText="11位手机号"/>

        <!-- 姓名 -->
        <Label text="姓名:*" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <TextField fx:id="nameField"
                   GridPane.columnIndex="3" GridPane.rowIndex="1"
                   prefWidth="150" promptText="会员姓名"/>

        <!-- 积分 -->
        <Label text="积分:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="pointsField"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"
                   prefWidth="150" promptText="0"/>

        <!-- 等级 -->
        <Label text="等级:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
        <ComboBox fx:id="levelComboBox"
                  GridPane.columnIndex="3" GridPane.rowIndex="2"
                  prefWidth="150"/>

        <!-- 折扣 -->
        <Label text="折扣:*" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="discountField"
                   GridPane.columnIndex="1" GridPane.rowIndex="3"
                   prefWidth="150" promptText="10.0"/>
        
        <!-- 折扣说明 -->
        <Label text="说明: 0=免费, 10=不打折"
               GridPane.columnIndex="0" GridPane.rowIndex="4"
               style="-fx-text-fill: #757575; -fx-font-size: 10px;"/>

        <!-- 余额 -->
        <Label text="余额(元):" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
        <TextField fx:id="balanceField"
                   GridPane.columnIndex="3" GridPane.rowIndex="3"
                   prefWidth="150" promptText="0.00"/>

        <!-- 生日 -->
        <Label text="生日:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="birthdayField"
                   GridPane.columnIndex="1" GridPane.rowIndex="5"
                   prefWidth="150" promptText="MM-dd (可选)"/>
    </GridPane>

    <!-- 分隔线 -->
    <Separator/>

    <!-- 错误提示 -->
    <Label fx:id="errorLabel" 
           text="" 
           style="-fx-text-fill: #F44336; -fx-font-size: 12px;"/>

    <!-- 按钮区域 -->
    <HBox spacing="15" alignment="CENTER_RIGHT">
        <padding>
            <Insets top="10"/>
        </padding>
        <Button fx:id="cancelButton"
                text="取消"
                onAction="#handleCancel"
                prefWidth="100"
                prefHeight="35"
                styleClass="secondary-button"/>
        <Button fx:id="saveButton"
                text="保存"
                onAction="#handleSave"
                prefWidth="100"
                prefHeight="35"
                styleClass="primary-button"/>
    </HBox>

</VBox>