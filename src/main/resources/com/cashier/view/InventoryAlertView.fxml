<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.InventoryAlertController"
      spacing="0"
      styleClass="inventory-alert-view">

    <!-- 顶部工具栏 -->
    <VBox spacing="5" styleClass="toolbar">
        <!-- 第一行：标题和服务状态 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="5" left="10"/>
            </padding>

            <Label text="%inventory_alert.title" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>

            <Separator orientation="VERTICAL" style="-fx-padding: 0 10 0 10;"/>

            <Label text="%inventory_alert.service_status" style="-fx-font-size: 13px; -fx-text-fill: #424242;"/>
            <Label fx:id="serviceStatusLabel" text="%inventory_alert.service_not_started" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Circle fx:id="statusIndicator" radius="6" fill="#9E9E9E"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="lastCheckTimeLabel" text="%inventory_alert.last_check" style="-fx-font-size: 12px; -fx-text-fill: #757575;"/>
        </HBox>

        <!-- 第二行：配置信息和操作按钮 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="5" right="10" bottom="10" left="10"/>
            </padding>

            <Label text="%inventory_alert.check_interval" style="-fx-font-size: 13px; -fx-text-fill: #424242;"/>
            <Label fx:id="checkIntervalLabel" text="%inventory_alert.interval_5min" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

            <Label text="%inventory_alert.cooldown_time" style="-fx-font-size: 13px; -fx-text-fill: #424242;"/>
            <Label fx:id="alertCooldownLabel" text="%inventory_alert.cooldown_1hour" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

            <Separator orientation="VERTICAL" style="-fx-padding: 0 10 0 10;"/>

            <Button fx:id="refreshButton"
                    text="%inventory_alert.check_now"
                    onAction="#handleRefresh"
                    prefWidth="100"
                    styleClass="primary-button"/>

            <Button fx:id="clearCooldownButton"
                    text="%inventory_alert.clear_cooldown"
                    onAction="#handleClearCooldown"
                    prefWidth="120"
                    styleClass="secondary-button"/>

            <Button fx:id="exportButton"
                    text="%inventory_alert.export_alert"
                    onAction="#handleExport"
                    prefWidth="100"
                    styleClass="info-button"/>
        </HBox>
    </VBox>

    <!-- 统计信息 -->
    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="alert-stats">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <VBox spacing="5">
            <Label text="%inventory_alert.alert_count" style="-fx-font-size: 12px; -fx-text-fill: #757575;"/>
            <Label fx:id="alertCountLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #F44336;"/>
        </VBox>

        <VBox spacing="5">
            <Label text="%inventory_alert.critical" style="-fx-font-size: 12px; -fx-text-fill: #757575;"/>
            <Label fx:id="criticalCountLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #D32F2F;"/>
        </VBox>

        <VBox spacing="5">
            <Label text="%inventory_alert.warning" style="-fx-font-size: 12px; -fx-text-fill: #757575;"/>
            <Label fx:id="warningCountLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
        </VBox>

        <VBox spacing="5">
            <Label text="%inventory_alert.info" style="-fx-font-size: 12px; -fx-text-fill: #757575;"/>
            <Label fx:id="infoCountLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
        </VBox>
    </HBox>

    <!-- 预警商品表格 -->
    <TableView fx:id="alertTable"
              VBox.vgrow="ALWAYS"
              styleClass="alert-table">
        <columns>
            <TableColumn fx:id="nameColumn" text="%inventory_alert.product_name" prefWidth="200"/>
            <TableColumn fx:id="productCodeColumn" text="%inventory_alert.product_code" prefWidth="120"/>
            <TableColumn fx:id="currentStockColumn" text="%inventory_alert.current_stock" prefWidth="100"/>
            <TableColumn fx:id="minStockColumn" text="%inventory_alert.min_stock" prefWidth="100"/>
            <TableColumn fx:id="unitColumn" text="%inventory_alert.unit" prefWidth="80"/>
            <TableColumn fx:id="alertLevelColumn" text="%inventory_alert.alert_level" prefWidth="120"/>
            <TableColumn fx:id="lastAlertTimeColumn" text="%inventory_alert.last_alert_time" prefWidth="180"/>
        </columns>
        <placeholder>
            <Label text="%inventory_alert.no_data"/>
        </placeholder>
    </TableView>

    <!-- 底部操作栏 -->
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bottom-actions">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <Button fx:id="closeButton"
                text="%inventory_alert.close"
                onAction="#handleClose"
                prefWidth="100"
                styleClass="secondary-button"/>
    </HBox>

</VBox>
