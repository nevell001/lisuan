<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.PurchaseInboundController"
      spacing="0"
      styleClass="purchase-inbound-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 操作按钮 -->
        <Button fx:id="inboundButton"
                text="执行入库"
                onAction="#handleInbound"
                prefWidth="100"
                disable="true"
                styleClass="success-button"/>

        <Button fx:id="viewDetailButton"
                text="查看详情"
                onAction="#handleViewDetail"
                prefWidth="100"
                disable="true"
                styleClass="info-button"/>

        <Button fx:id="viewHistoryButton"
                text="入库历史"
                onAction="#handleViewHistory"
                prefWidth="100"
                styleClass="secondary-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 搜索 -->
        <Label text="搜索:"/>
        <TextField fx:id="searchField"
                  promptText="输入订单号或供应商"
                  prefWidth="200"
                  onAction="#handleSearch"/>

        <Button text="搜索"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button text="刷新"
                onAction="#handleRefresh"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 统计信息 -->
        <Label fx:id="countLabel" text="可入库订单: 0 条" style="-fx-text-fill: #757575;"/>
    </HBox>

    <!-- 可入库订单表格 -->
    <TableView fx:id="orderTable"
              VBox.vgrow="ALWAYS"
              styleClass="purchase-inbound-table">
        <columns>
            <TableColumn fx:id="orderNoColumn" text="订单号" prefWidth="150"/>
            <TableColumn fx:id="supplierColumn" text="供应商" prefWidth="150"/>
            <TableColumn fx:id="purchaseDateColumn" text="采购日期" prefWidth="100"/>
            <TableColumn fx:id="totalAmountColumn" text="总金额(元)" prefWidth="100"/>
            <TableColumn fx:id="purchaserColumn" text="采购人" prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="暂无可入库订单" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>