<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.ReturnReportController"
      spacing="10" styleClass="main-container">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- 顶部工具栏 -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="退货报表统计" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="reportTypeComboBox" prefWidth="120"/>
        <DatePicker fx:id="startDatePicker" prefWidth="150" promptText="开始日期"/>
        <DatePicker fx:id="endDatePicker" prefWidth="150" promptText="结束日期"/>
        <Button text="生成报表" onAction="#handleGenerate" styleClass="primary-button"/>
        <Button text="刷新" onAction="#handleRefresh"/>
        <Button text="导出" onAction="#handleExport" styleClass="success-button"/>
    </HBox>

    <!-- 统计摘要 -->
    <HBox spacing="15" style="-fx-background-color: #f5f5f5; -fx-padding: 15;">
        <VBox spacing="5" prefWidth="150">
            <Label text="退货订单数" style="-fx-font-weight: bold;"/>
            <Label fx:id="totalReturnOrdersLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: blue;"/>
        </VBox>
        <VBox spacing="5" prefWidth="150">
            <Label text="退货总金额" style="-fx-font-weight: bold;"/>
            <Label fx:id="totalReturnAmountLabel" text="¥0.00" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: red;"/>
        </VBox>
        <VBox spacing="5" prefWidth="150">
            <Label text="平均退货金额" style="-fx-font-weight: bold;"/>
            <Label fx:id="avgReturnAmountLabel" text="¥0.00" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox spacing="5" prefWidth="120">
            <Label text="待审批" style="-fx-font-weight: bold;"/>
            <Label fx:id="pendingOrdersLabel" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: orange;"/>
        </VBox>
        <VBox spacing="5" prefWidth="120">
            <Label text="已批准" style="-fx-font-weight: bold;"/>
            <Label fx:id="approvedOrdersLabel" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: green;"/>
        </VBox>
        <VBox spacing="5" prefWidth="120">
            <Label text="已拒绝" style="-fx-font-weight: bold;"/>
            <Label fx:id="rejectedOrdersLabel" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: red;"/>
        </VBox>
        <VBox spacing="5" prefWidth="120">
            <Label text="已完成" style="-fx-font-weight: bold;"/>
            <Label fx:id="completedOrdersLabel" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: blue;"/>
        </VBox>
    </HBox>

    <!-- 图表区域 -->
    <HBox spacing="15" VBox.vgrow="ALWAYS">
        <!-- 状态饼图 -->
        <VBox spacing="5" prefWidth="400">
            <Label text="退货订单状态分布" style="-fx-font-weight: bold;"/>
            <PieChart fx:id="statusPieChart" VBox.vgrow="ALWAYS"/>
        </VBox>

        <!-- 退货趋势图 -->
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="退货金额趋势" style="-fx-font-weight: bold;"/>
            <BarChart fx:id="returnTrendBarChart" VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis label="日期"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="金额（元）"/>
                </yAxis>
            </BarChart>
        </VBox>
    </HBox>

    <!-- 分类退货统计 -->
    <VBox spacing="5" VBox.vgrow="ALWAYS" prefHeight="300">
        <Label text="分类退货统计" style="-fx-font-weight: bold;"/>
        <BarChart fx:id="categoryReturnBarChart" VBox.vgrow="ALWAYS">
            <xAxis>
                <CategoryAxis label="分类"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="退货金额（元）"/>
            </yAxis>
        </BarChart>
    </VBox>

    <!-- 退货订单列表 -->
    <VBox spacing="5" VBox.vgrow="ALWAYS">
        <Label text="退货订单详情" style="-fx-font-weight: bold;"/>
        <TableView fx:id="returnOrderTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="returnOrderIdColumn" text="退货单号" prefWidth="150"/>
                <TableColumn fx:id="memberNameColumn" text="会员名称" prefWidth="100"/>
                <TableColumn fx:id="returnDateColumn" text="退货日期" prefWidth="150"/>
                <TableColumn fx:id="totalAmountColumn" text="退货金额" prefWidth="100"/>
                <TableColumn fx:id="statusColumn" text="状态" prefWidth="80"/>
                <TableColumn fx:id="operatorNameColumn" text="操作员" prefWidth="80"/>
            </columns>
        </TableView>
    </VBox>
</VBox>