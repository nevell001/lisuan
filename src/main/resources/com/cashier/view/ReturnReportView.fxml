<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.ReturnReportController"
      spacing="10" styleClass="main-container">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- 顶部工具栏 -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="%return_report.title" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="reportTypeComboBox" prefWidth="120"/>
        <DatePicker fx:id="startDatePicker" prefWidth="150" promptText="%return_report.start_date"/>
        <DatePicker fx:id="endDatePicker" prefWidth="150" promptText="%return_report.end_date"/>
        <Button text="%return_report.generate" onAction="#handleGenerate" styleClass="primary-button"/>
        <Button text="%return_report.refresh" onAction="#handleRefresh"/>
        <Button text="%return_report.export" onAction="#handleExport" styleClass="success-button"/>
    </HBox>

    <!-- 统计摘要 -->
    <HBox spacing="15" style="-fx-background-color: #f5f5f5; -fx-padding: 15;">
        <VBox spacing="5" prefWidth="150">
            <Label text="%return_report.total_orders" style="-fx-font-weight: bold;"/>
            <Label fx:id="totalReturnOrdersLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: blue;"/>
        </VBox>
        <VBox spacing="5" prefWidth="150">
            <Label text="%return_report.total_amount" style="-fx-font-weight: bold;"/>
            <Label fx:id="totalReturnAmountLabel" text="¥0.00" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: red;"/>
        </VBox>
        <VBox spacing="5" prefWidth="150">
            <Label text="%return_report.avg_amount" style="-fx-font-weight: bold;"/>
            <Label fx:id="avgReturnAmountLabel" text="¥0.00" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox spacing="5" prefWidth="120">
            <Label text="%return_report.pending_orders" style="-fx-font-weight: bold;"/>
            <Label fx:id="pendingOrdersLabel" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: orange;"/>
        </VBox>
        <VBox spacing="5" prefWidth="120">
            <Label text="%return_report.approved_orders" style="-fx-font-weight: bold;"/>
            <Label fx:id="approvedOrdersLabel" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: green;"/>
        </VBox>
        <VBox spacing="5" prefWidth="120">
            <Label text="%return_report.rejected_orders" style="-fx-font-weight: bold;"/>
            <Label fx:id="rejectedOrdersLabel" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: red;"/>
        </VBox>
        <VBox spacing="5" prefWidth="120">
            <Label text="%return_report.completed_orders" style="-fx-font-weight: bold;"/>
            <Label fx:id="completedOrdersLabel" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: blue;"/>
        </VBox>
    </HBox>

    <!-- 图表区域 -->
    <HBox spacing="15" VBox.vgrow="ALWAYS">
        <!-- 状态饼图 -->
        <VBox spacing="5" prefWidth="400">
            <Label text="%return_report.status_distribution" style="-fx-font-weight: bold;"/>
            <PieChart fx:id="statusPieChart" VBox.vgrow="ALWAYS"/>
        </VBox>

        <!-- 退货趋势图 -->
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="%return_report.amount_trend" style="-fx-font-weight: bold;"/>
            <BarChart fx:id="returnTrendBarChart" VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis label="%return_report.date"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="%return_report.amount"/>
                </yAxis>
            </BarChart>
        </VBox>
    </HBox>

    <!-- 分类退货统计 -->
    <VBox spacing="5" VBox.vgrow="ALWAYS" prefHeight="300">
        <Label text="%return_report.category_statistics" style="-fx-font-weight: bold;"/>
        <BarChart fx:id="categoryReturnBarChart" VBox.vgrow="ALWAYS">
            <xAxis>
                <CategoryAxis label="%return_report.category"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="%return_report.amount"/>
            </yAxis>
        </BarChart>
    </VBox>

    <!-- 退货订单列表 -->
    <VBox spacing="5" VBox.vgrow="ALWAYS">
        <Label text="%return_report.order_details" style="-fx-font-weight: bold;"/>
        <TableView fx:id="returnOrderTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="returnOrderIdColumn" text="%return_report.return_id" prefWidth="150"/>
                <TableColumn fx:id="memberNameColumn" text="%return_report.member_name" prefWidth="100"/>
                <TableColumn fx:id="returnDateColumn" text="%return_approval.return_date" prefWidth="150"/>
                <TableColumn fx:id="totalAmountColumn" text="%return_report.total_amount" prefWidth="100"/>
                <TableColumn fx:id="statusColumn" text="%return_report.status" prefWidth="80"/>
                <TableColumn fx:id="operatorNameColumn" text="%return_approval.operator" prefWidth="80"/>
            </columns>
        </TableView>
    </VBox>
</VBox>