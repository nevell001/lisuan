<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.UserController"
      spacing="0"
      styleClass="user-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 操作按钮 -->
        <Button fx:id="addButton"
                text="%user.add"
                onAction="#handleAddUser"
                prefWidth="100"
                styleClass="primary-button"/>

        <Button fx:id="editButton"
                text="%user.edit_button"
                onAction="#handleEditUser"
                prefWidth="80"
                styleClass="secondary-button"/>

        <Button fx:id="deleteButton"
                text="%user.delete_button"
                onAction="#handleDeleteUser"
                prefWidth="80"
                styleClass="danger-button"/>

        <Button fx:id="resetPasswordButton"
                text="%user.reset_password"
                onAction="#handleResetPassword"
                prefWidth="100"
                styleClass="warning-button"/>

        <Separator orientation="VERTICAL"/>

        <Button fx:id="activateButton"
                text="%user.activate"
                onAction="#handleActivateUser"
                prefWidth="80"
                styleClass="success-button"/>

        <Button fx:id="deactivateButton"
                text="%user.deactivate"
                onAction="#handleDeactivateUser"
                prefWidth="80"
                styleClass="warning-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 筛选条件 -->
        <Label text="%user.role_label"/>
        <ComboBox fx:id="roleFilterComboBox" prefWidth="100"/>

        <Label text="%user.status_label"/>
        <ComboBox fx:id="statusFilterComboBox" prefWidth="100"/>

        <Label text="%user.search_label"/>
        <TextField fx:id="searchField"
                  promptText="%user.search_hint"
                  prefWidth="150"
                  onAction="#handleSearch"/>

        <Button text="%common.search"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button text="%common.clear"
                onAction="#handleClearSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 统计信息 -->
        <Label fx:id="countLabel" text="%user.count" style="-fx-text-fill: #757575;"/>
    </HBox>

    <!-- 用户列表表格 -->
    <TableView fx:id="userTable"
              VBox.vgrow="ALWAYS"
              styleClass="user-table">
        <columns>
            <TableColumn fx:id="usernameColumn" text="%user.username" prefWidth="120"/>
            <TableColumn fx:id="nameColumn" text="%user.real_name" prefWidth="120"/>
            <TableColumn fx:id="roleColumn" text="%user.role" prefWidth="100"/>
            <TableColumn fx:id="createTimeColumn" text="%user.create_time" prefWidth="160"/>
            <TableColumn fx:id="lastLoginColumn" text="%user.last_login" prefWidth="160"/>
            <TableColumn fx:id="statusColumn" text="%user.status" prefWidth="80"/>
        </columns>
        <placeholder>
            <Label text="%user.no_data" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>