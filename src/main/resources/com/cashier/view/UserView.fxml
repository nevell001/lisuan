<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.UserController"
      spacing="0"
      styleClass="user-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 操作按钮 -->
        <Button fx:id="addButton"
                text="添加用户"
                onAction="#handleAddUser"
                prefWidth="100"
                styleClass="primary-button"/>

        <Button fx:id="editButton"
                text="编辑"
                onAction="#handleEditUser"
                prefWidth="80"
                styleClass="secondary-button"/>

        <Button fx:id="deleteButton"
                text="删除"
                onAction="#handleDeleteUser"
                prefWidth="80"
                styleClass="danger-button"/>

        <Button fx:id="resetPasswordButton"
                text="重置密码"
                onAction="#handleResetPassword"
                prefWidth="100"
                styleClass="warning-button"/>

        <Separator orientation="VERTICAL"/>

        <Button fx:id="activateButton"
                text="激活"
                onAction="#handleActivateUser"
                prefWidth="80"
                styleClass="success-button"/>

        <Button fx:id="deactivateButton"
                text="禁用"
                onAction="#handleDeactivateUser"
                prefWidth="80"
                styleClass="warning-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 筛选条件 -->
        <Label text="角色:"/>
        <ComboBox fx:id="roleFilterComboBox" prefWidth="100"/>

        <Label text="状态:"/>
        <ComboBox fx:id="statusFilterComboBox" prefWidth="100"/>

        <Label text="搜索:"/>
        <TextField fx:id="searchField"
                  promptText="用户名或姓名"
                  prefWidth="150"
                  onAction="#handleSearch"/>

        <Button text="搜索"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button text="清除"
                onAction="#handleClearSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 统计信息 -->
        <Label fx:id="countLabel" text="用户数量: 0" style="-fx-text-fill: #757575;"/>
    </HBox>

    <!-- 用户列表表格 -->
    <TableView fx:id="userTable"
              VBox.vgrow="ALWAYS"
              styleClass="user-table">
        <columns>
            <TableColumn fx:id="usernameColumn" text="用户名" prefWidth="120"/>
            <TableColumn fx:id="nameColumn" text="姓名" prefWidth="120"/>
            <TableColumn fx:id="roleColumn" text="角色" prefWidth="100"/>
            <TableColumn fx:id="createTimeColumn" text="创建时间" prefWidth="160"/>
            <TableColumn fx:id="lastLoginColumn" text="最后登录" prefWidth="160"/>
            <TableColumn fx:id="statusColumn" text="状态" prefWidth="80"/>
        </columns>
        <placeholder>
            <Label text="暂无用户数据" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>