<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.PasswordResetController"
      spacing="20"
      styleClass="password-reset-dialog">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <!-- 标题 -->
    <Label text="重置密码"
           styleClass="dialog-title"/>

    <!-- 说明信息 -->
    <Label text="请输入您的用户名和注册邮箱，我们将向您发送重置密码的链接。"
           styleClass="dialog-description"
           wrapText="true"/>

    <!-- 表单 -->
    <VBox spacing="15">
        <!-- 用户名 -->
        <VBox spacing="8">
            <Label text="用户名" styleClass="form-label"/>
            <TextField fx:id="usernameField"
                       promptText="请输入用户名"
                       prefWidth="300"
                       styleClass="dialog-input"/>
        </VBox>

        <!-- 邮箱 -->
        <VBox spacing="8">
            <Label text="注册邮箱" styleClass="form-label"/>
            <TextField fx:id="emailField"
                       promptText="请输入注册邮箱"
                       prefWidth="300"
                       styleClass="dialog-input"/>
        </VBox>

        <!-- 错误提示 -->
        <Label fx:id="errorLabel"
               styleClass="error-label"
               visible="false"
               managed="false"/>

        <!-- 成功提示 -->
        <Label fx:id="successLabel"
               styleClass="success-label"
               visible="false"
               managed="false"/>
    </VBox>

    <!-- 按钮 -->
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding-top: 10;">
        <Button text="取消"
                onAction="#handleCancel"
                prefWidth="100"
                prefHeight="35"
                styleClass="secondary-button"/>
        <Button fx:id="submitButton"
                text="发送重置链接"
                onAction="#handleSubmit"
                prefWidth="120"
                prefHeight="35"
                styleClass="primary-button"/>
    </HBox>

</VBox>