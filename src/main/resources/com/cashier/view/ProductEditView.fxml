<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.ProductEditController"
      spacing="15"
      styleClass="product-edit-view"
      prefWidth="500"
      prefHeight="600">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- 标题 -->
    <Label fx:id="titleLabel" 
           text="添加商品" 
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>

    <!-- 表单 -->
    <GridPane hgap="10" vgap="10" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="10" right="0" bottom="10" left="0"/>
        </padding>

        <!-- 商品名称 -->
        <Label text="商品名称:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="0" 
                   prefWidth="300"/>

        <!-- 单价 -->
        <Label text="单价(元):" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="priceField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="1" 
                   prefWidth="300" promptText="0.00"/>

        <!-- 库存数量 -->
        <Label text="库存数量:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="quantityField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="2" 
                   prefWidth="300" promptText="0"/>

        <!-- 最低库存 -->
        <Label text="最低库存:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="minStockField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="3" 
                   prefWidth="300" promptText="10"/>

        <!-- 分类 -->
        <Label text="分类:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="categoryField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="4" 
                   prefWidth="300" promptText="默认分类"/>

        <!-- 条形码 -->
        <Label text="条形码:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="barcodeField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="5" 
                   prefWidth="300" promptText="可选"/>

        <!-- 单位 -->
        <Label text="单位:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <TextField fx:id="unitField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="6" 
                   prefWidth="300" promptText="个"/>

        <!-- 商品描述 -->
        <Label text="商品描述:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        <TextArea fx:id="descriptionField" 
                  GridPane.columnIndex="1" GridPane.rowIndex="7" 
                  prefWidth="300" prefHeight="60" 
                  promptText="可选"/>

        <!-- 品牌 -->
        <Label text="品牌:" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
        <TextField fx:id="brandField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="8" 
                   prefWidth="300" promptText="可选"/>

        <!-- 供应商 -->
        <Label text="供应商:" GridPane.columnIndex="0" GridPane.rowIndex="9"/>
        <TextField fx:id="supplierField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="9" 
                   prefWidth="300" promptText="可选"/>

        <!-- 规格 -->
        <Label text="规格:" GridPane.columnIndex="0" GridPane.rowIndex="10"/>
        <TextField fx:id="specField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="10" 
                   prefWidth="300" promptText="可选"/>

        <!-- 成本价 -->
        <Label text="成本价(元):" GridPane.columnIndex="0" GridPane.rowIndex="11"/>
        <TextField fx:id="costField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="11" 
                   prefWidth="300" promptText="0.00"/>
    </GridPane>

    <!-- 错误提示 -->
    <Label fx:id="errorLabel" 
           text="" 
           style="-fx-text-fill: #F44336; -fx-font-size: 12px;"/>

    <!-- 按钮区域 -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="cancelButton"
                text="取消"
                onAction="#handleCancel"
                prefWidth="80"
                styleClass="secondary-button"/>
        <Button fx:id="saveButton"
                text="保存"
                onAction="#handleSave"
                prefWidth="80"
                styleClass="primary-button"/>
    </HBox>

</VBox>