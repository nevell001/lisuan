<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.InventoryReportController"
      spacing="0"
      styleClass="statistics-view">

    <!-- 顶部工具栏 -->
    <VBox spacing="5" styleClass="toolbar">
        <!-- 第一行：时间范围和筛选 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="5" left="10"/>
            </padding>

            <Label text="%inventory_report.time_range"/>
            <ComboBox fx:id="timeRangeComboBox" prefWidth="120"/>

            <Label text="%inventory_report.start_date"/>
            <DatePicker fx:id="startDatePicker" prefWidth="150"/>

            <Label text="%inventory_report.end_date"/>
            <DatePicker fx:id="endDatePicker" prefWidth="150"/>

            <Label text="%inventory_report.category_label"/>
            <ComboBox fx:id="categoryComboBox" prefWidth="150"/>
        </HBox>

        <!-- 第二行：阈值设置和操作按钮 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="5" right="10" bottom="10" left="10"/>
            </padding>

            <Label text="%inventory_report.turnover_threshold"/>
            <TextField fx:id="turnoverThresholdField" prefWidth="80" promptText="1.0"/>

            <Label text="%inventory_report.slow_sales_threshold"/>
            <TextField fx:id="slowSalesThresholdField" prefWidth="80" promptText="10"/>

            <Label text="%inventory_report.inventory_days"/>
            <TextField fx:id="inventoryDaysField" prefWidth="80" promptText="90"/>

            <Separator orientation="VERTICAL"/>

            <Button fx:id="queryButton"
                    text="%inventory_report.query"
                    onAction="#handleQuery"
                    prefWidth="100"
                    prefHeight="35"
                    styleClass="primary-button"/>

            <Button fx:id="exportButton"
                    text="%inventory_report.export"
                    onAction="#handleExport"
                    prefWidth="100"
                    prefHeight="35"
                    styleClass="secondary-button"/>
        </HBox>
    </VBox>

    <!-- 主要内容区域：使用 SplitPane 分割上中下三部分 -->
    <SplitPane VBox.vgrow="ALWAYS" orientation="VERTICAL" dividerPositions="0.25,0.58">
        
        <!-- 上部（1/4）：数据汇总 - 紧凑的两行布局 -->
        <VBox styleClass="cards-container">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>
            <GridPane hgap="10" vgap="8">
                <!-- 第一行：3列 -->
                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%inventory_report.total_products" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="totalProductsLabel" text="0" style="-fx-text-fill: #3F51B5; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%inventory_report.total_stock_value" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="totalStockValueLabel" text="¥0.00" style="-fx-text-fill: #4CAF50; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%inventory_report.avg_turnover_rate" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="avgTurnoverRateLabel" text="0.00" style="-fx-text-fill: #FF9800; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- 第二行：3列 -->
                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%inventory_report.low_stock" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="lowStockCountLabel" text="0" style="-fx-text-fill: #F44336; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%inventory_report.slow_sales" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="slowSalesCountLabel" text="0" style="-fx-text-fill: #9C27B0; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%inventory_report.overstock" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="overstockCountLabel" text="0" style="-fx-text-fill: #00BCD4; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- 中部（1/3）：图表区域 -->
        <VBox styleClass="charts-container">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>
            <GridPane hgap="15" vgap="10">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="25"/>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="25"/>
                </columnConstraints>

                <!-- 库存状态分布饼图 -->
                <VBox spacing="8" styleClass="chart-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <Label text="%inventory_report.stock_status" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
                    <PieChart fx:id="stockStatusPieChart" VBox.vgrow="ALWAYS" legendSide="RIGHT"/>
                </VBox>

                <!-- 库存周转率分析柱状图 -->
                <VBox spacing="8" styleClass="chart-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <Label text="%inventory_report.turnover_analysis" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                    <BarChart fx:id="turnoverRateBarChart" VBox.vgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis label="%inventory_report.product_axis"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="%inventory_report.turnover_axis"/>
                        </yAxis>
                    </BarChart>
                </VBox>

                <!-- 分类库存价值柱状图 -->
                <VBox spacing="8" styleClass="chart-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <Label text="%inventory_report.category_stock_value" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    <BarChart fx:id="categoryStockValueBarChart" VBox.vgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis label="%product.category"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="%inventory_report.stock_value_axis"/>
                        </yAxis>
                    </BarChart>
                </VBox>
            </GridPane>
        </VBox>

        <!-- 底部：商品库存列表 - 使用 TabPane 支持多个表格 -->
        <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
            <padding>
                <Insets top="5" right="10" bottom="5" left="10"/>
            </padding>
            
            <!-- 库存预警列表 Tab -->
            <Tab text="%inventory_report.tab_alert">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="5" right="10" bottom="5" left="10"/>
                    </padding>
                    <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="productNameColumn" text="%product.name" prefWidth="200"/>
                            <TableColumn fx:id="categoryColumn" text="%product.category" prefWidth="100"/>
                            <TableColumn fx:id="currentStockColumn" text="%inventory_report.current_stock" prefWidth="100"/>
                            <TableColumn fx:id="stockValueColumn" text="%inventory_report.stock_value" prefWidth="120"/>
                            <TableColumn fx:id="salesQuantityColumn" text="%inventory_report.sales_quantity" prefWidth="100"/>
                            <TableColumn fx:id="turnoverRateColumn" text="%inventory_report.turnover_rate" prefWidth="100"/>
                            <TableColumn fx:id="inventoryDaysColumn" text="%inventory_report.inventory_days_column" prefWidth="100"/>
                            <TableColumn fx:id="statusColumn" text="%inventory_report.status" prefWidth="100"/>
                        </columns>
                    </TableView>
                </ScrollPane>
            </Tab>

            <!-- 滞销商品列表 Tab -->
            <Tab text="%inventory_report.tab_slow_sales">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="5" right="10" bottom="5" left="10"/>
                    </padding>
                    <TableView fx:id="slowSalesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="slowProductNameColumn" text="%product.name" prefWidth="200"/>
                            <TableColumn fx:id="slowCategoryColumn" text="%product.category" prefWidth="100"/>
                            <TableColumn fx:id="currentStockColumn2" text="%inventory_report.current_stock" prefWidth="100"/>
                            <TableColumn fx:id="salesQuantityColumn2" text="%inventory_report.sales_quantity" prefWidth="100"/>
                            <TableColumn fx:id="lastSaleDateColumn" text="%inventory_report.last_sale_date" prefWidth="120"/>
                        </columns>
                    </TableView>
                </ScrollPane>
            </Tab>

            <!-- 积压商品列表 Tab -->
            <Tab text="%inventory_report.tab_overstock">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="5" right="10" bottom="5" left="10"/>
                    </padding>
                    <TableView fx:id="overstockTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="overstockProductNameColumn" text="%product.name" prefWidth="200"/>
                            <TableColumn fx:id="overstockCategoryColumn" text="%product.category" prefWidth="100"/>
                            <TableColumn fx:id="overstockQuantityColumn" text="%inventory_report.overstock_quantity" prefWidth="100"/>
                            <TableColumn fx:id="overstockValueColumn" text="%inventory_report.overstock_value" prefWidth="120"/>
                            <TableColumn fx:id="overstockDaysColumn" text="%inventory_report.overstock_days" prefWidth="100"/>
                        </columns>
                    </TableView>
                </ScrollPane>
            </Tab>
        </TabPane>
    </SplitPane>

</VBox>