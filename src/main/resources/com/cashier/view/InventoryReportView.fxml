<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.InventoryReportController"
      spacing="0"
      styleClass="statistics-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 时间范围选择 -->
        <Label text="时间范围:"/>
        <ComboBox fx:id="timeRangeComboBox" prefWidth="120"/>

        <Label text="开始日期:"/>
        <DatePicker fx:id="startDatePicker" prefWidth="150"/>

        <Label text="结束日期:"/>
        <DatePicker fx:id="endDatePicker" prefWidth="150"/>

        <Label text="分类:"/>
        <ComboBox fx:id="categoryComboBox" prefWidth="150"/>

        <Separator orientation="VERTICAL"/>

        <!-- 阈值设置 -->
        <Label text="周转率阈值:"/>
        <TextField fx:id="turnoverThresholdField" prefWidth="80" promptText="1.0"/>

        <Label text="滞销阈值:"/>
        <TextField fx:id="slowSalesThresholdField" prefWidth="80" promptText="10"/>

        <Label text="库存天数:"/>
        <TextField fx:id="inventoryDaysField" prefWidth="80" promptText="90"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 操作按钮 -->
        <Button fx:id="queryButton"
                text="查询"
                onAction="#handleQuery"
                prefWidth="100"
                prefHeight="35"
                styleClass="primary-button"/>

        <Button fx:id="exportButton"
                text="导出"
                onAction="#handleExport"
                prefWidth="100"
                prefHeight="35"
                styleClass="secondary-button"/>
    </HBox>

    <!-- 主要内容区域：使用 SplitPane 分割上中下三部分 -->
    <SplitPane VBox.vgrow="ALWAYS" orientation="VERTICAL" dividerPositions="0.25,0.58">
        
        <!-- 上部（1/4）：数据汇总 - 紧凑的两行布局 -->
        <VBox styleClass="cards-container">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>
            <GridPane hgap="10" vgap="8">
                <!-- 第一行：3列 -->
                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="总商品数" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="totalProductsLabel" text="0" style="-fx-text-fill: #3F51B5; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="总库存价值" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="totalStockValueLabel" text="¥0.00" style="-fx-text-fill: #4CAF50; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="平均周转率" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="avgTurnoverRateLabel" text="0.00" style="-fx-text-fill: #FF9800; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- 第二行：3列 -->
                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="库存不足" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="lowStockCountLabel" text="0" style="-fx-text-fill: #F44336; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="滞销商品" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="slowSalesCountLabel" text="0" style="-fx-text-fill: #9C27B0; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="积压商品" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="overstockCountLabel" text="0" style="-fx-text-fill: #00BCD4; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- 中部（1/3）：图表区域 -->
        <VBox styleClass="charts-container">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>
            <GridPane hgap="15" vgap="10">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="25"/>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="25"/>
                </columnConstraints>

                <!-- 库存状态分布饼图 -->
                <VBox spacing="8" styleClass="chart-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <Label text="库存状态分布" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
                    <PieChart fx:id="stockStatusPieChart" VBox.vgrow="ALWAYS" legendSide="RIGHT"/>
                </VBox>

                <!-- 库存周转率分析柱状图 -->
                <VBox spacing="8" styleClass="chart-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <Label text="库存周转率分析" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                    <BarChart fx:id="turnoverRateBarChart" VBox.vgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis label="商品"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="周转率"/>
                        </yAxis>
                    </BarChart>
                </VBox>

                <!-- 分类库存价值柱状图 -->
                <VBox spacing="8" styleClass="chart-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <Label text="分类库存价值" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    <BarChart fx:id="categoryStockValueBarChart" VBox.vgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis label="分类"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="库存价值（元）"/>
                        </yAxis>
                    </BarChart>
                </VBox>
            </GridPane>
        </VBox>

        <!-- 底部：商品库存列表 - 使用 TabPane 支持多个表格 -->
        <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
            <padding>
                <Insets top="5" right="10" bottom="5" left="10"/>
            </padding>
            
            <!-- 库存预警列表 Tab -->
            <Tab text="库存预警列表">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="5" right="10" bottom="5" left="10"/>
                    </padding>
                    <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="productNameColumn" text="商品名称" prefWidth="200"/>
                            <TableColumn fx:id="categoryColumn" text="分类" prefWidth="100"/>
                            <TableColumn fx:id="currentStockColumn" text="当前库存" prefWidth="100"/>
                            <TableColumn fx:id="stockValueColumn" text="库存价值" prefWidth="120"/>
                            <TableColumn fx:id="salesQuantityColumn" text="销售数量" prefWidth="100"/>
                            <TableColumn fx:id="turnoverRateColumn" text="周转率" prefWidth="100"/>
                            <TableColumn fx:id="inventoryDaysColumn" text="库存天数" prefWidth="100"/>
                            <TableColumn fx:id="statusColumn" text="状态" prefWidth="100"/>
                        </columns>
                    </TableView>
                </ScrollPane>
            </Tab>

            <!-- 滞销商品列表 Tab -->
            <Tab text="滞销商品列表">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="5" right="10" bottom="5" left="10"/>
                    </padding>
                    <TableView fx:id="slowSalesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="slowProductNameColumn" text="商品名称" prefWidth="200"/>
                            <TableColumn fx:id="slowCategoryColumn" text="分类" prefWidth="100"/>
                            <TableColumn fx:id="currentStockColumn2" text="当前库存" prefWidth="100"/>
                            <TableColumn fx:id="salesQuantityColumn2" text="销售数量" prefWidth="100"/>
                            <TableColumn fx:id="lastSaleDateColumn" text="最后销售日期" prefWidth="120"/>
                        </columns>
                    </TableView>
                </ScrollPane>
            </Tab>

            <!-- 积压商品列表 Tab -->
            <Tab text="积压商品列表">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="5" right="10" bottom="5" left="10"/>
                    </padding>
                    <TableView fx:id="overstockTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="overstockProductNameColumn" text="商品名称" prefWidth="200"/>
                            <TableColumn fx:id="overstockCategoryColumn" text="分类" prefWidth="100"/>
                            <TableColumn fx:id="overstockQuantityColumn" text="库存数量" prefWidth="100"/>
                            <TableColumn fx:id="overstockValueColumn" text="库存价值" prefWidth="120"/>
                            <TableColumn fx:id="overstockDaysColumn" text="库存天数" prefWidth="100"/>
                        </columns>
                    </TableView>
                </ScrollPane>
            </Tab>
        </TabPane>
    </SplitPane>

</VBox>