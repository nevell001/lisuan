<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.MemberController"
      spacing="0"
      styleClass="member-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 操作按钮 -->
        <Button fx:id="addButton"
                text="%member.add"
                onAction="#handleAddMember"
                prefWidth="100"
                styleClass="primary-button"/>

        <Button fx:id="editButton"
                text="%member.edit"
                onAction="#handleEditMember"
                prefWidth="80"
                styleClass="secondary-button"/>

        <Button fx:id="deleteButton"
                text="%member.delete"
                onAction="#handleDeleteMember"
                prefWidth="80"
                styleClass="danger-button"/>

        <Button fx:id="rechargeButton"
                text="%member.recharge_action"
                onAction="#handleRecharge"
                prefWidth="80"
                styleClass="info-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 搜索 -->
        <Label text="%member.search_label"/>
        <TextField fx:id="searchField"
                  promptText="%member.search_hint"
                  prefWidth="200"
                  onAction="#handleSearch"/>

        <Button text="%member.search_button"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button text="%member.clear"
                onAction="#handleClearSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 统计信息 -->
        <Label fx:id="countLabel" text="%member.count" style="-fx-text-fill: #757575;"/>
    </HBox>

    <!-- 会员表格 -->
    <TableView fx:id="memberTable"
              VBox.vgrow="ALWAYS"
              styleClass="member-table">
        <columns>
            <TableColumn fx:id="phoneColumn" text="%member.phone" prefWidth="120"/>
            <TableColumn fx:id="nameColumn" text="%member.name" prefWidth="100"/>
            <TableColumn fx:id="levelColumn" text="%member.level" prefWidth="80"/>
            <TableColumn fx:id="pointsColumn" text="%member.points" prefWidth="80"/>
            <TableColumn fx:id="balanceColumn" text="%member.balance" prefWidth="100"/>
            <TableColumn fx:id="discountColumn" text="%member.discount" prefWidth="80"/>
            <TableColumn fx:id="birthdayColumn" text="%member.birthday" prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="%member.no_data" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>
