<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cashier.controller.PurchaseReportController"
      spacing="0"
      styleClass="statistics-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 时间范围选择 -->
        <Label text="%purchase_report.time_range"/>
        <ComboBox fx:id="timeRangeComboBox" prefWidth="120"/>

        <Label text="%purchase_report.start_date"/>
        <DatePicker fx:id="startDatePicker" prefWidth="150"/>

        <Label text="%purchase_report.end_date"/>
        <DatePicker fx:id="endDatePicker" prefWidth="150"/>

        <Label text="%purchase_report.supplier_label"/>
        <ComboBox fx:id="supplierComboBox" prefWidth="200"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 操作按钮 -->
        <Button fx:id="queryButton"
                text="%purchase_report.query"
                onAction="#handleQuery"
                prefWidth="100"
                prefHeight="35"
                styleClass="primary-button"/>

        <Button fx:id="exportButton"
                text="%purchase_report.export"
                onAction="#handleExport"
                prefWidth="100"
                prefHeight="35"
                styleClass="secondary-button"/>
    </HBox>

    <!-- 主要内容区域：使用 SplitPane 分割上中下三部分 -->
    <SplitPane VBox.vgrow="ALWAYS" orientation="VERTICAL" dividerPositions="0.25,0.58">
        
        <!-- 上部（1/4）：数据汇总 - 紧凑的两行布局 -->
        <VBox styleClass="cards-container">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>
            <GridPane hgap="10" vgap="8">
                <!-- 第一行：4列 -->
                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%purchase_report.total_orders" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="totalOrdersLabel" text="0" style="-fx-text-fill: #3F51B5; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%purchase_report.total_amount" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="totalAmountLabel" text="¥0.00" style="-fx-text-fill: #4CAF50; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%purchase_report.total_quantity" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="totalQuantityLabel" text="0" style="-fx-text-fill: #FF9800; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="3" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%purchase_report.avg_order_amount" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="avgOrderAmountLabel" text="¥0.00" style="-fx-text-fill: #9C27B0; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- 第二行：3列 -->
                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%purchase_report.pending_orders" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="pendingOrdersLabel" text="0" style="-fx-text-fill: #F44336; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%purchase_report.approved_orders" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="approvedOrdersLabel" text="0" style="-fx-text-fill: #2196F3; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card-compact" GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.columnSpan="2" GridPane.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="%purchase_report.completed_orders" style="-fx-text-fill: #757575; -fx-font-size: 11px;"/>
                    <Label fx:id="completedOrdersLabel" text="0" style="-fx-text-fill: #00BCD4; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- 中部（1/3）：图表区域 -->
        <VBox styleClass="charts-container">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>
            <GridPane hgap="15" vgap="10">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="25"/>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="25"/>
                </columnConstraints>

                <!-- 订单状态分布饼图 -->
                <VBox spacing="8" styleClass="chart-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <Label text="%purchase_report.status_distribution" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>
                    <PieChart fx:id="statusPieChart" VBox.vgrow="ALWAYS" legendSide="RIGHT"/>
                </VBox>

                <!-- 采购金额趋势折线图 -->
                <VBox spacing="8" styleClass="chart-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <Label text="%purchase_report.amount_trend" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                    <LineChart fx:id="amountTrendLineChart" VBox.vgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis label="%purchase_report.date_axis"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="%purchase_report.amount_axis"/>
                        </yAxis>
                    </LineChart>
                </VBox>

                <!-- 供应商对比柱状图 -->
                <VBox spacing="8" styleClass="chart-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <Label text="%purchase_report.supplier_comparison" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    <BarChart fx:id="supplierComparisonBarChart" VBox.vgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis label="%purchase_report.supplier_axis"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="%purchase_report.amount_axis"/>
                        </yAxis>
                    </BarChart>
                </VBox>
            </GridPane>
        </VBox>

        <!-- 底部：采购订单列表 - 使用 TabPane 支持多个表格 -->
        <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
            <padding>
                <Insets top="5" right="10" bottom="5" left="10"/>
            </padding>

            <!-- 采购订单明细 Tab -->
            <Tab text="%purchase_report.tab_orders">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="5" right="10" bottom="5" left="10"/>
                    </padding>
                    <TableView fx:id="orderTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="orderNoColumn" text="%purchase_report.order_no" prefWidth="150"/>
                            <TableColumn fx:id="supplierColumn" text="%purchase_report.supplier" prefWidth="200"/>
                            <TableColumn fx:id="dateColumn" text="%purchase_report.order_date" prefWidth="120"/>
                            <TableColumn fx:id="amountColumn" text="%purchase_report.order_amount" prefWidth="120"/>
                            <TableColumn fx:id="quantityColumn" text="%purchase_report.product_quantity" prefWidth="100"/>
                            <TableColumn fx:id="statusColumn" text="%purchase_report.status" prefWidth="100"/>
                        </columns>
                    </TableView>
                </ScrollPane>
            </Tab>

            <!-- 供应商采购排名 Tab -->
            <Tab text="%purchase_report.tab_suppliers">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="5" right="10" bottom="5" left="10"/>
                    </padding>
                    <TableView fx:id="supplierRankTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="rankColumn" text="%purchase_report.rank" prefWidth="80"/>
                            <TableColumn fx:id="supplierNameColumn" text="%purchase_report.supplier_name" prefWidth="200"/>
                            <TableColumn fx:id="orderCountColumn" text="%purchase_report.order_count" prefWidth="100"/>
                            <TableColumn fx:id="supplierAmountColumn" text="%purchase_report.supplier_amount" prefWidth="150"/>
                        </columns>
                    </TableView>
                </ScrollPane>
            </Tab>

            <!-- 分类采购统计 Tab -->
            <Tab text="%purchase_report.tab_category">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="5" right="10" bottom="5" left="10"/>
                    </padding>
                    <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="categoryColumn" text="%purchase_report.category" prefWidth="150"/>
                            <TableColumn fx:id="categoryQuantityColumn" text="%purchase_report.category_quantity" prefWidth="100"/>
                            <TableColumn fx:id="categoryAmountColumn" text="%purchase_report.category_amount" prefWidth="150"/>
                        </columns>
                    </TableView>
                </ScrollPane>
            </Tab>
        </TabPane>
    </SplitPane>

</VBox>