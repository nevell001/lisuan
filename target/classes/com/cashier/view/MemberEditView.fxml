<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.MemberEditController"
      spacing="15"
      styleClass="member-edit-view"
      prefWidth="400"
      prefHeight="500">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- 标题 -->
    <Label fx:id="titleLabel" 
           text="添加会员" 
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3F51B5;"/>

    <!-- 表单 -->
    <GridPane hgap="10" vgap="10" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="10" right="0" bottom="10" left="0"/>
        </padding>

        <!-- 手机号 -->
        <Label text="手机号:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="phoneField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="0" 
                   prefWidth="250" promptText="11位手机号"/>

        <!-- 姓名 -->
        <Label text="姓名:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="nameField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="1" 
                   prefWidth="250" promptText="会员姓名"/>

        <!-- 积分 -->
        <Label text="积分:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="pointsField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="2" 
                   prefWidth="250" promptText="0"/>

        <!-- 等级 -->
        <Label text="等级:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="levelComboBox" 
                  GridPane.columnIndex="1" GridPane.rowIndex="3" 
                  prefWidth="250"/>

        <!-- 折扣 -->
        <Label text="折扣:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="discountField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="4" 
                   prefWidth="250" promptText="1.0"/>

        <!-- 余额 -->
        <Label text="余额(元):" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="balanceField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="5" 
                   prefWidth="250" promptText="0.00"/>

        <!-- 生日 -->
        <Label text="生日:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <TextField fx:id="birthdayField" 
                   GridPane.columnIndex="1" GridPane.rowIndex="6" 
                   prefWidth="250" promptText="MM-dd (可选)"/>
    </GridPane>

    <!-- 错误提示 -->
    <Label fx:id="errorLabel" 
           text="" 
           style="-fx-text-fill: #F44336; -fx-font-size: 12px;"/>

    <!-- 按钮区域 -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="cancelButton"
                text="取消"
                onAction="#handleCancel"
                prefWidth="80"
                styleClass="secondary-button"/>
        <Button fx:id="saveButton"
                text="保存"
                onAction="#handleSave"
                prefWidth="80"
                styleClass="primary-button"/>
    </HBox>

</VBox>