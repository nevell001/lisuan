<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cashier.controller.InventoryController"
      spacing="0"
      styleClass="inventory-view">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- 操作按钮 -->
        <Button fx:id="addButton"
                text="添加商品"
                onAction="#handleAddProduct"
                prefWidth="100"
                styleClass="primary-button"/>

        <Button fx:id="editButton"
                text="编辑"
                onAction="#handleEditProduct"
                prefWidth="80"
                styleClass="secondary-button"/>

        <Button fx:id="deleteButton"
                text="删除"
                onAction="#handleDeleteProduct"
                prefWidth="80"
                styleClass="danger-button"/>

        <Button fx:id="restockButton"
                text="补货"
                onAction="#handleRestock"
                prefWidth="80"
                styleClass="info-button"/>

        <Separator orientation="VERTICAL"/>

        <!-- 搜索和排序 -->
        <Label text="搜索:"/>
        <TextField fx:id="searchField"
                  promptText="输入商品名称搜索"
                  prefWidth="200"
                  onAction="#handleSearch"/>

        <Button text="搜索"
                onAction="#handleSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Button text="清除"
                onAction="#handleClearSearch"
                prefWidth="60"
                styleClass="secondary-button"/>

        <Label text="排序:"/>
        <ComboBox fx:id="sortComboBox" prefWidth="150"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- 统计信息 -->
        <Label fx:id="countLabel" text="商品数量: 0" style="-fx-text-fill: #757575;"/>
    </HBox>

    <!-- 商品表格 -->
    <TableView fx:id="inventoryTable"
              VBox.vgrow="ALWAYS"
              styleClass="inventory-table">
        <columns>
            <TableColumn fx:id="nameColumn" text="商品名称" prefWidth="200"/>
            <TableColumn fx:id="priceColumn" text="单价(元)" prefWidth="100"/>
            <TableColumn fx:id="quantityColumn" text="库存" prefWidth="80"/>
            <TableColumn fx:id="minStockColumn" text="最低库存" prefWidth="80"/>
            <TableColumn fx:id="categoryColumn" text="分类" prefWidth="120"/>
            <TableColumn fx:id="warningColumn" text="预警状态" prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="暂无商品数据" style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

</VBox>
